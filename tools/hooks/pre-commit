#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# pre-commit: blocca il commit se vengono modificati file narrativi
# senza aggiornare la documentazione Obsidian nelle ultime GRACE secondi.
#
# File considerati "narrativi":
#   lib/widgets/minigame_*.dart
#   lib/main.dart
#   lib/models/comic_data.dart
#   assets/data/quests/**/*.json
#
# Override: git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

ROOT="$(git rev-parse --show-toplevel)"
BIBLE="$ROOT/docs/NARRATIVE_BIBLE.md"
MAPPA="$ROOT/docs/MAPPA_NARRATIVA.md"
GRACE=3600  # 60 minuti di grace period

# Raccoglie i file narrativi staged
STAGED=$(git diff --cached --name-only)
NARRATIVE=$(echo "$STAGED" | grep -E \
  "^(lib/widgets/minigame_|lib/main\.dart|lib/models/comic_data\.dart|assets/data/quests/)")

# Se nessun file narrativo è staged, lascia passare
if [ -z "$NARRATIVE" ]; then
  exit 0
fi

# ─── JSON validation ─────────────────────────────────────────────────────────
# Valida ogni file .json staged. Blocca se malformato.
JSON_FILES=$(echo "$STAGED" | grep "\.json$")
if [ -n "$JSON_FILES" ]; then
  JSON_ERRORS=0
  while IFS= read -r f; do
    if [ -f "$ROOT/$f" ]; then
      ERR=$(python3 -c "import json,sys; json.load(open('$ROOT/$f'))" 2>&1)
      if [ $? -ne 0 ]; then
        echo ""
        echo "❌  JSON non valido: $f"
        echo "    $ERR" | sed 's/^/    /'
        JSON_ERRORS=1
      fi
    fi
  done <<< "$JSON_FILES"

  if [ $JSON_ERRORS -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  🚨  JSON MALFORMATO — commit bloccato                      ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  Correggi i file JSON elencati sopra e riprova.             ║"
    echo "║  Override: git commit --no-verify                           ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    exit 1
  fi
fi

# Controlla se i doc sono stati modificati di recente.
# stat -L per seguire i symlink (necessario su macOS).
NOW=$(date +%s)
bible_mtime=$(stat -L -f %m "$BIBLE" 2>/dev/null || echo 0)
mappa_mtime=$(stat -L -f %m "$MAPPA" 2>/dev/null || echo 0)
last_update=$(( bible_mtime > mappa_mtime ? bible_mtime : mappa_mtime ))
elapsed=$(( NOW - last_update ))

if [ "$elapsed" -gt "$GRACE" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  📚  DOCUMENTAZIONE NON AGGIORNATA — commit bloccato        ║"
  echo "╠══════════════════════════════════════════════════════════════╣"
  echo "║  File narrativi nel commit:                                  ║"
  while IFS= read -r f; do
    [ -n "$f" ] && printf "║    • %-56s║\n" "$f"
  done <<< "$NARRATIVE"
  echo "╠══════════════════════════════════════════════════════════════╣"
  printf "║  Docs Obsidian non aggiornate (ultima modifica: %3dm fa)  ║\n" "$(( elapsed / 60 ))"
  echo "║                                                              ║"
  echo "║  Aggiorna almeno uno di:                                     ║"
  echo "║    • docs/NARRATIVE_BIBLE.md  (mini-game table, authoring)  ║"
  echo "║    • docs/MAPPA_NARRATIVA.md  (branch diagram)              ║"
  echo "║                                                              ║"
  echo "║  Poi riprova. Override: git commit --no-verify              ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

min_ago=$(( elapsed / 60 ))
echo "📚  Docs aggiornate ${min_ago}m fa — ok."
exit 0
