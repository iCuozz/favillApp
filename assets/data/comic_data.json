  "episodes": [
    {
      "id": "prologo",
      "title": "L'ombra della fiamma",
      "subtitle": "La doppia vita di Favilla",
      "thumbnail": "assets/episodes/prologo/thumb0.png",
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/prologo/page_0.png",
          "panels": [
            {
              "id": "pr0_0",
              "characters": ["favilla", "bambini"],
              "text_blocks": [
                {
                  "id": "pr0_0_tb_0",
                  "type": "narration",
                  "text": "Nova Tutinia, scuola elementare. Di giorno sono Favilla, collaboratrice scolastica. Gestisco 50 piccoli uragani ogni giorno."
                },
                {
                  "id": "pr0_0_tb_1",
                  "type": "dialogue",
                  "speaker": "bimbo_1",
                  "text": "Favilla! Hai visto la mia gomma?!?"
                },
                {
                  "id": "pr0_0_tb_2",
                  "type": "dialogue",
                  "speaker": "bimbo_2",
                  "text": "È mia! L'ho trovata prima io!"
                },
                {
                  "id": "pr0_0_tb_3",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Ragazzi...attenti che la gomma è magica, se litigate vi cancella i giocattoli!"
                },
                {
                  "id": "pr0_0_tb_4",
                  "type": "narration",
                  "text": "Se sapeste cosa mi aspetta a casa..."
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 1,
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "pr1_0",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "pr1_0_tb_0",
                  "type": "narration",
                  "text": "Poi c'è casa. Il vero campo di battaglia si chiama Sparkle Ale."
                },
                {
                  "id": "pr1_0_tb_1",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "MAMMAAA! LATTE! GIOCHI! CAOSMAX!"
                },
                {
                  "id": "pr1_0_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Ale piccolo, un disastro alla volta!"
                },
                {
                  "id": "pr1_0_tb_3",
                  "type": "narration",
                  "text": "Lui è Mallow Bellow, il papà informatico. Programma software, ma spesso manda in crash la casa."
                },
                {
                  "id": "pr1_0_tb_4",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Latte overflow..."
                },
                {
                  "id": "pr1_0_tb_5",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Papà bug! Mamma fix!"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 2,
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "pr2_0",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "pr2_0_tb_0",
                  "type": "narration",
                  "text": "Colazioni esplosive, panni infiniti, giochi ovunque. Questo è il mio allenamento quotidiano."
                },
                {
                  "id": "pr2_0_tb_1",
                  "type": "narration",
                  "text": "Siri: \"Disordine domestico: 92%. Tempo stimato per l'ordine: 47 ore.\""
                },
                {
                  "id": "pr2_0_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Ale, il cucchiaio si mangia, non si lancia in orbita!"
                },
                {
                  "id": "pr2_0_tb_3",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Cucchiaio razzo!"
                },
                {
                  "id": "pr2_0_tb_4",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Ho inventato il frisbee-calzino!"
                },
                {
                  "id": "pr2_0_tb_5",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Papà campione caos!"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 3,
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "pr3_0",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "pr3_0_tb_0",
                  "type": "narration",
                  "text": "Ma ogni giorno arriva il momento in cui il caos supera il limite."
                },
                {
                  "id": "pr3_0_tb_1",
                  "type": "narration",
                  "text": "Giocattoli ovunque, pentole che fumano, panni che invadono il divano."
                },
                {
                  "id": "pr3_0_tb_2",
                  "type": "narration",
                  "text": "Il portatile di Mallow Bellow lampeggia: \"COMPILATION FAILED\"."
                },
                {
                  "id": "pr3_0_tb_3",
                  "type": "narration",
                  "text": "Siri: \"ALLERTA! Disordine 99%! Evacuare immediatamente!\""
                },
                {
                  "id": "pr3_0_tb_4",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "CAOS TOTALE! VINCITORI!"
                },
                {
                  "id": "pr3_0_tb_5",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Il sistema è completamente down..."
                },
                {
                  "id": "pr3_0_tb_6",
                  "type": "narration",
                  "text": "Favilla chiude gli occhi. Due caos. Una scintilla dentro di lei."
                },
                {
                  "id": "pr3_0_tb_7",
                  "type": "thought",
                  "text": "È ora."
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 4,
          "background": "assets/episodes/prologo/page_4.png",
          "panels": [
            {
              "id": "pr4_0",
              "characters": ["favilla_blaze", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "pr4_0_tb_0",
                  "type": "narration",
                  "text": "In un lampo, gli occhiali spariscono, il maglioncino svanisce, i suoi capelli biondi diventano una criniera di fuoco."
                },
                {
                  "id": "pr4_0_tb_1",
                  "type": "narration",
                  "text": "La tuta da collaboratrice lascia spazio a un costume super-palestra con fiamme rosa e oro. L'aura intorno a lei esplode di energia."
                },
                {
                  "id": "pr4_0_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla_blaze",
                  "text": "Superpoteri supermamma: ATTIVATI!"
                },
                {
                  "id": "pr4_0_tb_3",
                  "type": "narration",
                  "text": "Dall'ombra della scuola... nasce FAVILLA BLAZE."
                },
                {
                  "id": "pr4_0_tb_4",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Ho... sposato una supereroina?"
                },
                {
                  "id": "pr4_0_tb_5",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Mamma FLAMMA!"
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    {
      "id": "missione_1",
      "title": "Missione #1 – Caos all'Alba",
      "subtitle": "Favilla Blaze contro il risveglio più difficile",
      "thumbnail": "assets/episodes/missione_1/thumb1.png",
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/missione_1/page1_0.png",
          "panels": [
            {
              "id": "m1_0",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "m1_0_tb_0",
                  "type": "narration",
                  "text": "È ancora buio a Nova Tutinia. Nel piccolo appartamento al terzo piano, il mondo sembra dormire."
                },
                {
                  "id": "m1_0_tb_1",
                  "type": "narration",
                  "text": "Favilla dorme sfinita. Mallow Bellow russa con il portatile acceso sul petto."
                },
                {
                  "id": "m1_0_tb_2",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "MAMMMAAAA! LATTEEE! ORA!"
                },
                {
                  "id": "m1_0_tb_3",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Compilazione... notturna... in corso..."
                },
                {
                  "id": "m1_0_tb_4",
                  "type": "thought",
                  "text": "Missione n.1: sopravvivenza."
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 1,
          "background": "assets/episodes/missione_1/page1_1.png",
          "panels": [
            {
              "id": "m1_1",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "m1_1_tb_0",
                  "type": "narration",
                  "text": "La cucina è il primo campo di battaglia."
                },
                {
                  "id": "m1_1_tb_1",
                  "type": "narration",
                  "text": "Favilla tiene Sparkle Ale sul fianco, mentre con una mano frulla pancake proteici e con il piede chiude un cassetto ribelle."
                },
                {
                  "id": "m1_1_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Precisione livello 10, piccolo disastro nucleare!"
                },
                {
                  "id": "m1_1_tb_3",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Cucchiaio razzo!"
                },
                {
                  "id": "m1_1_tb_4",
                  "type": "narration",
                  "text": "Il cucchiaio parte davvero, sfiora Mallow Bellow e rimbalza sul frigo."
                },
                {
                  "id": "m1_1_tb_5",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Colpito... e quasi affondato."
                }
              ],
              "interactions": [
                {
                  "type": "tap",
                  "target": "cucchiaio",
                  "effect": "shake",
                  "sound": "clang"
                }
              ]
            }
          ]
        },
        {
          "index": 2,
          "background": "assets/episodes/missione_1/page1_2.png",
          "panels": [
            {
              "id": "m1_2",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "m1_2_tb_0",
                  "type": "narration",
                  "text": "Nel salotto-palestra, la guerriera si allena."
                },
                {
                  "id": "m1_2_tb_1",
                  "type": "narration",
                  "text": "Favilla fa squat con Sparkle Ale agganciato al petto come uno zainetto vivente."
                },
                {
                  "id": "m1_2_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Resistenza: estrema. Determinazione: infinita."
                },
                {
                  "id": "m1_2_tb_3",
                  "type": "narration",
                  "text": "Mallow Bellow, in un angolo, prova a fare plank. Dura esattamente tre secondi."
                },
                {
                  "id": "m1_2_tb_4",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Resistenza 404 Not Found."
                },
                {
                  "id": "m1_2_tb_5",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Mamma SUPER! Papà morbido!"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 3,
          "background": "assets/episodes/missione_1/page1_3.png",
          "panels": [
            {
              "id": "m1_3",
              "characters": ["favilla_blaze", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "m1_3_tb_0",
                  "type": "narration",
                  "text": "Poi arriva lei. La Montagna dei Panni Sporchi. Nemico antico, mai davvero sconfitto."
                },
                {
                  "id": "m1_3_tb_1",
                  "type": "narration",
                  "text": "Favilla Blaze la fissa. L'aura intorno a lei aumenta di intensità."
                },
                {
                  "id": "m1_3_tb_2",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Ho scritto un algoritmo per piegare i panni!"
                },
                {
                  "id": "m1_3_tb_3",
                  "type": "narration",
                  "text": "Clic. Una valanga di magliette e calzini si riversa sul pavimento."
                },
                {
                  "id": "m1_3_tb_4",
                  "type": "dialogue",
                  "speaker": "favilla_blaze",
                  "text": "Ordine Quantico: attivazione."
                },
                {
                  "id": "m1_3_tb_5",
                  "type": "narration",
                  "text": "I panni cominciano a piegarsi come per magia, seguendo i suoi gesti esperti."
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 4,
          "background": "assets/episodes/missione_1/page1_4.png",
          "panels": [
            {
              "id": "m1_4",
              "characters": ["favilla_blaze", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "m1_4_tb_0",
                  "type": "narration",
                  "text": "Mallow Bellow e Sparkle Ale osservano affascinati, in un attimo la casa è in perfetto ordine, il caos è stato sconfitto."
                },
                {
                  "id": "m1_4_tb_1",
                  "type": "dialogue",
                  "speaker": "mallow_bellow",
                  "text": "Wow... sei incredibile, Favilla Blaze!"
                },
                {
                  "id": "m1_4_tb_2",
                  "type": "dialogue",
                  "speaker": "sparkle_ale",
                  "text": "Mamma SUPER! Mamma MAGICA!"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 5,
          "background": "assets/episodes/missione_1/page1_5.png",
          "panels": [
            {
              "id": "m1_5",
              "characters": ["favilla", "sparkle_ale", "mallow_bellow"],
              "text_blocks": [
                {
                  "id": "m1_5_tb_0",
                  "type": "narration",
                  "text": "La sera, il caos si spegne. Per qualche ora."
                },
                {
                  "id": "m1_5_tb_1",
                  "type": "narration",
                  "text": "Sparkle Ale si addormenta attaccato alla tetta della mamma, abbracciato come un piccolo koala, dentro il suo sacco nanna."
                },
                {
                  "id": "m1_5_tb_2",
                  "type": "narration",
                  "text": "Mallow Bellow dorme seduto, mussola sulle ginocchia."
                },
                {
                  "id": "m1_5_tb_3",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Forse non salvo il mondo. Ma oggi ho vinto contro il caos del mio mondo."
                },
                {
                  "id": "m1_5_tb_4",
                  "type": "narration",
                  "text": "Una piccola favilla di luce parte dal suo cuore e illumina la stanza."
                },
                {
                  "id": "m1_5_tb_5",
                  "type": "narration",
                  "text": "Favilla Blaze. L'eroina della quale Sparkle Ale e Mallow Bellow hanno bisogno."
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    }
  ]
}
