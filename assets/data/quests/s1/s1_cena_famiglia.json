{
  "id": "s1_cena_famiglia",
  "audio_theme": "ritorno_casa",
  "stat_entry": [
    {
      "stat": "legame",
      "op": "gte",
      "value": 70,
      "goto_branch": "intro_calda",
      "prepend": true
    }
  ],
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/prologo/page_1.png",
      "panels": [
        {
          "id": "cena_p0_a",
          "characters": [
            "mallow",
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "cena_p0_a_t1",
              "type": "narration",
              "text": "Sera. La cucina profuma di burro e uova. Mallow è ai fornelli con l'aria di chi sta per svelare un segreto di famiglia."
            },
            {
              "id": "cena_p0_a_t2",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Due uova. Le apri così, ci metti dentro il formaggio, le chiudi a calzone. Le friggi nel burro. Mia nonna lo chiamava calzuovo."
            },
            {
              "id": "cena_p0_a_t3",
              "type": "narration",
              "text": "Lex lo fissa dal seggiolone. Non il calzuovo. Lui. Con occhi da detective."
            },
            {
              "id": "cena_p0_a_t4",
              "type": "dialogue",
              "speaker": "favilla",
              "text": "Calzuovo. Mi piace. Suona come una cosa che si mangia e poi si va in battaglia."
            },
            {
              "id": "cena_p0_a_t5",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Esatto. È il piatto dei guerrieri. O almeno dei programmatori affamati."
            }
          ]
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/prologo/page_2.png",
      "panels": [
        {
          "id": "cena_p1_a",
          "characters": [
            "mallow",
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "cena_p1_a_t1",
              "type": "narration",
              "text": "Il calzuovo arriva in tavola. Mallow lo serve con l'orgoglio di uno chef stellato. Lex lo guarda. Poi guarda Favilla. Poi di nuovo Mallow."
            },
            {
              "id": "cena_p1_a_t2",
              "type": "thought",
              "speaker": "favilla",
              "text": "Sta tramando. Lo vedo. Ha la stessa faccia del reparto pasta."
            },
            {
              "id": "cena_p1_a_t3",
              "type": "narration",
              "text": "Lex spinge via il piatto. Non mangia. Aguzza gli occhi. Punta il ditino verso Favilla, poi verso Mallow. Come un direttore d'orchestra silenzioso."
            },
            {
              "id": "cena_p1_a_t4",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Ma che hai stasera? Non ti piace il calzuovo?"
            },
            {
              "id": "cena_p1_a_t5",
              "type": "thought",
              "speaker": "favilla",
              "text": "Non è il calzuovo. È sua madre. Sta cercando di dirtelo."
            }
          ]
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/prologo/page_3.png",
      "panels": [
        {
          "id": "cena_p2_a",
          "characters": [
            "mallow",
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "cena_p2_a_t1",
              "type": "narration",
              "text": "Lex ora ha messo in scena un piccolo sabotaggio. Il cucchiaio cade. Poi la tazza. Poi altre tre cose in rapida successione. Ogni volta indica Favilla."
            },
            {
              "id": "cena_p2_a_t2",
              "type": "narration",
              "text": "Mallow lo guarda. Poi guarda Favilla. Poi di nuovo Lex. Qualcosa scatta."
            },
            {
              "id": "cena_p2_a_t3",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Sai che è strano? Da qualche settimana, ogni volta che succede qualcosa di... strano, Lex guarda te. Non me. Te."
            },
            {
              "id": "cena_p2_a_t4",
              "type": "thought",
              "speaker": "favilla",
              "text": "Lo sa. Non lo sa. Ma lo sente. E Lex glielo sta servendo su un piatto d'argento."
            }
          ]
        }
      ]
    },
    {
      "index": 3,
      "background": "assets/episodes/prologo/page_1.png",
      "panels": [
        {
          "id": "cena_p3_a",
          "characters": [
            "mallow",
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "cena_p3_a_t1",
              "type": "narration",
              "text": "Mallow posa la forchetta. La cena è a metà. Lex ha smesso di lanciare oggetti e ora fissa il padre con un'intensità quasi comica."
            },
            {
              "id": "cena_p3_a_t2",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Favilla. C'è qualcosa che non mi stai dicendo."
            },
            {
              "id": "cena_p3_a_t3",
              "type": "narration",
              "text": "Non è arrabbiato. È... dolce. Come se le stesse chiedendo il permesso di sapere. Lex trattiene il respiro."
            }
          ],
          "choice": {
            "id": "cena_choice",
            "prompt": "Mallow ti guarda. Lex pure. La cena è una polveriera.",
            "options": [
              {
                "id": "confessa_piccolo",
                "label": "«Mallow... devo dirti una cosa. Quella domenica al parco...»",
                "goto_branch": "branch_confessa",
                "stat_effects": {
                  "legame": 8,
                  "segreto": -10
                },
                "set_flags": {
                  "cena_famiglia_fatta": true
                },
                "set_memories": {
                  "choice.s1_cena_famiglia": "confessa_piccolo"
                }
              },
              {
                "id": "facciata",
                "label": "«Lex, mangia. Mallow, è buonissimo. Tutto a posto.»",
                "goto_branch": "branch_facciata",
                "stat_effects": {
                  "segreto": 8,
                  "resistenza": 5
                },
                "set_flags": {
                  "cena_famiglia_fatta": true
                },
                "set_memories": {
                  "choice.s1_cena_famiglia": "facciata"
                }
              },
              {
                "id": "umorismo",
                "label": "«Mallow, tuo figlio sta cercando di fare il regista. O forse il matchmaker.»",
                "goto_branch": "branch_umorismo",
                "stat_effects": {
                  "legame": 5,
                  "scintille": 5
                },
                "set_flags": {
                  "cena_famiglia_fatta": true
                },
                "set_memories": {
                  "choice.s1_cena_famiglia": "umorismo"
                }
              },
              {
                "id": "distrai_lex",
                "label": "Guardi Lex. Ha i pastelli in mano. Sta disegnando qualcosa.",
                "stat_effects": {
                  "segreto": -3
                },
                "set_flags": {
                  "cena_famiglia_fatta": true
                },
                "set_memories": {
                  "choice.s1_cena_famiglia": "distrai_lex"
                },
                "minigame": {
                  "type": "disegna",
                  "tiers": [
                    {
                      "min": 4,
                      "label": "Disegno innocuo.",
                      "goto_branch": "branch_disegno_innocuo",
                      "stat_effects": {
                        "legame": 8,
                        "scintille": 5
                      }
                    },
                    {
                      "min": 2,
                      "label": "Quasi...",
                      "goto_branch": "branch_disegno_quasi",
                      "stat_effects": {
                        "segreto": -5,
                        "legame": 3
                      }
                    },
                    {
                      "min": 0,
                      "label": "Mallow ha visto.",
                      "goto_branch": "branch_disegno_visto",
                      "stat_effects": {
                        "segreto": -12,
                        "legame": 5
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "branches": {
    "intro_calda": {
      "id": "intro_calda",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "intro_calda_a",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "intro_calda_a_t1",
                  "type": "narration",
                  "text": "Mallow ha passato il pomeriggio ai fornelli. Il calzuovo non è solo una ricetta — è il suo modo di dire 'ti voglio bene' senza doverlo dire."
                },
                {
                  "id": "intro_calda_a_t2",
                  "type": "narration",
                  "text": "Favilla lo sa. Ed è proprio questo calore che rischia di perdere se un giorno lui scopre tutto."
                },
                {
                  "id": "intro_calda_a_t3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Ho pensato che dopo la settimana che hai passato... ti meritavi una cena vera."
                },
                {
                  "id": "intro_calda_a_t4",
                  "type": "narration",
                  "text": "Lex dal seggiolone osserva la scena. Calcola. Stasera papà è dalla sua parte."
                }
              ]
            }
          ],
          "id": "icalda_p0"
        }
      ]
    },
    "branch_confessa": {
      "id": "branch_confessa",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "branch_confessa_a",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_confessa_a_t1",
                  "type": "narration",
                  "text": "Favilla posa la forchetta. Lex smette di respirare — o almeno così sembra, per un bambino di sette mesi e mezzo."
                },
                {
                  "id": "branch_confessa_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Quella domenica al parco... è successa una cosa. Non so come spiegarla. Nemmeno a me stessa."
                },
                {
                  "id": "branch_confessa_a_t3",
                  "type": "narration",
                  "text": "Mallow non dice niente. Le prende la mano. Aspetta."
                },
                {
                  "id": "branch_confessa_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Quando sei pronta, io ci sono. Non scappo da nessuna parte."
                },
                {
                  "id": "branch_confessa_a_t5",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Non tutta la verità. Ma un pezzo sì. Basta per stasera."
                }
              ]
            }
          ],
          "id": "bconfe_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_confessa_b",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_confessa_b_t1",
                  "type": "narration",
                  "text": "Lex rilascia il respiro. Poi sorride — quel sorriso complice con due dentini che solo Favilla sa decifrare."
                },
                {
                  "id": "branch_confessa_b_t2",
                  "type": "narration",
                  "text": "Il calzuovo è quasi freddo. Ma la mano di Mallow è ancora lì, sopra la sua."
                },
                {
                  "id": "branch_confessa_b_t3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Mangiamo, che si fredda. Poi mi racconti il resto."
                }
              ]
            }
          ],
          "id": "bconfe_p1"
        }
      ]
    },
    "branch_facciata": {
      "id": "branch_facciata",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "branch_facciata_a",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_facciata_a_t1",
                  "type": "narration",
                  "text": "Favilla sorride. È un sorriso ben allenato. Cambia discorso con la fluidità di chi lo fa da mesi."
                },
                {
                  "id": "branch_facciata_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Tutto a posto, davvero. Solo stanchezza. La Corvi, l'ispezione. Settimana pesante. Ma questo calzuovo è un miracolo."
                },
                {
                  "id": "branch_facciata_a_t3",
                  "type": "narration",
                  "text": "Mallow annuisce. Ma non ha smesso di guardarla. Lex sbuffa — frustrato, teatrale, definitivo."
                },
                {
                  "id": "branch_facciata_a_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Gli ho mentito di nuovo. E Lex lo sa. Ed è arrabbiato con me."
                }
              ]
            }
          ],
          "id": "bfacci_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_facciata_b",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_facciata_b_t1",
                  "type": "narration",
                  "text": "Mallow riprende a mangiare. Parla del lavoro, di una nuova libreria JavaScript. La serata deraglia nella normalità."
                },
                {
                  "id": "branch_facciata_b_t2",
                  "type": "narration",
                  "text": "Ma Lex non la guarda più. Ha le braccia incrociate sul seggiolone. Ha sette mesi ed è già capace di portare rancore."
                },
                {
                  "id": "branch_facciata_b_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Ho tenuto il segreto. Ma ho perso qualcosa con mio figlio. Lo recupererò domani. O forse no."
                }
              ]
            }
          ],
          "id": "bfacci_p1"
        }
      ]
    },
    "branch_umorismo": {
      "id": "branch_umorismo",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "branch_umorismo_a",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_umorismo_a_t1",
                  "type": "narration",
                  "text": "Favilla guarda Lex. Poi Mallow. Poi scoppia a ridere — quella risata vera, piena, che non usciva da giorni."
                },
                {
                  "id": "branch_umorismo_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Mallow, guardalo. Ha la faccia di uno che sta cercando di farci divorziare. È il nostro bambino, o un piccolo agente segreto?"
                },
                {
                  "id": "branch_umorismo_a_t3",
                  "type": "narration",
                  "text": "Lex fa il verso — una specie di pernacchia che suona come 'non sono un agente segreto ma ci sto lavorando'."
                },
                {
                  "id": "branch_umorismo_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Ha più carisma di me. Lo dico con orgoglio e un po' di paura."
                }
              ]
            }
          ],
          "id": "bumori_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_umorismo_b",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_umorismo_b_t1",
                  "type": "narration",
                  "text": "Ridono tutti e tre nello stesso momento. Il calzuovo è finito, ma non importa. Per un istante è solo una famiglia che cena."
                },
                {
                  "id": "branch_umorismo_b_t2",
                  "type": "narration",
                  "text": "Lex si addormenta poco dopo, la testa che ciondola. Ma ha un sorriso. Ha vinto qualcosa, anche se non sa ancora cosa."
                },
                {
                  "id": "branch_umorismo_b_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Domani sarà di nuovo tutto complicato. Ma stasera no. Stasera è nostro."
                }
              ]
            }
          ],
          "id": "bumori_p1"
        }
      ]
    },
    "branch_disegno_innocuo": {
      "id": "branch_disegno_innocuo",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "disegno_innocuo_a",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "disegno_innocuo_a_t1",
                  "type": "narration",
                  "text": "Lex guarda il suo stesso disegno. La mamma coi capelli a fuoco ora ha capelli normali. Le scintille sono diventate... stelle? Il dito puntato è una mano che saluta."
                },
                {
                  "id": "disegno_innocuo_a_t2",
                  "type": "narration",
                  "text": "Il suo capolavoro è stato modificato. Da qualcuno che aveva un pastello grigio e una conoscenza sospetta del suo piano."
                },
                {
                  "id": "disegno_innocuo_a_t3",
                  "type": "narration",
                  "text": "Lex fissa Favilla con l'espressione di chi ha appena perso una partita a scacchi. Mallow si avvicina, guarda il foglio."
                },
                {
                  "id": "disegno_innocuo_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Che bel disegno! Siamo noi? Guarda, quello sei tu, quelli siamo io e la mamma."
                }
              ]
            }
          ],
          "id": "bdiseg_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "disegno_innocuo_b",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "disegno_innocuo_b_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Sì. Noi tre."
                },
                {
                  "id": "disegno_innocuo_b_t2",
                  "type": "narration",
                  "text": "Mallow sorride. Lex incrocia le braccia sul seggiolone. Sconfitto. Per ora."
                },
                {
                  "id": "disegno_innocuo_b_t3",
                  "type": "narration",
                  "text": "Il calzuovo è quasi finito. Il disegno è innocuo. E Lex ha imparato che la mamma è più veloce di lui anche a tavola."
                },
                {
                  "id": "disegno_innocuo_b_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Bel tentativo, piccolo. Ma stasera vinco io."
                }
              ]
            }
          ],
          "id": "bdiseg_p1"
        }
      ]
    },
    "branch_disegno_quasi": {
      "id": "branch_disegno_quasi",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "disegno_quasi_a",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "disegno_quasi_a_t1",
                  "type": "narration",
                  "text": "Favilla modifica in fretta quello che può. Il risultato è un disegno strano: una figura coi capelli metà gialli e metà grigi, un'altra figura che sembra guardare ma anche no."
                },
                {
                  "id": "disegno_quasi_a_t2",
                  "type": "narration",
                  "text": "Un pastello rotola via. Lex lo segue con gli occhi. Favilla lo raccoglie prima che Mallow lo noti."
                },
                {
                  "id": "disegno_quasi_a_t3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Cos'è? Fammi vedere."
                },
                {
                  "id": "disegno_quasi_a_t4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Un autoritratto di Lex. Astratto. Ha talento."
                }
              ]
            }
          ],
          "id": "bdiseg_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "disegno_quasi_b",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "disegno_quasi_b_t1",
                  "type": "narration",
                  "text": "Lex la fulmina con lo sguardo. Mallow ride:"
                },
                {
                  "id": "disegno_quasi_b_t2",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Ha talento."
                },
                {
                  "id": "disegno_quasi_b_t3",
                  "type": "narration",
                  "text": "Ma ha esitato un secondo di troppo prima di ridere. Quel secondo in cui ha guardato il disegno più attentamente del necessario."
                },
                {
                  "id": "disegno_quasi_b_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Non ha capito. Ma ha sentito che c'è qualcosa da capire. Domani ci ripenserà."
                }
              ]
            }
          ],
          "id": "bdiseg_p1"
        }
      ]
    },
    "branch_disegno_visto": {
      "id": "branch_disegno_visto",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "disegno_visto_a",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "disegno_visto_a_t1",
                  "type": "narration",
                  "text": "Mallow si avvicina mentre Favilla ha ancora il pastello in mano. È troppo tardi. Vede il disegno originale: la figura coi capelli a fuoco, l'altra che guarda, Lex che indica."
                },
                {
                  "id": "disegno_visto_a_t2",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Chi è quella?"
                },
                {
                  "id": "disegno_visto_a_t3",
                  "type": "narration",
                  "text": "Indica i capelli di fuoco. Favilla prende il foglio, lo appallottola."
                },
                {
                  "id": "disegno_visto_a_t4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Niente. Roba da bambini."
                }
              ]
            }
          ],
          "id": "bdiseg_p0"
        },
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "disegno_visto_b",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "disegno_visto_b_t1",
                  "type": "narration",
                  "text": "Ma Mallow non distoglie lo sguardo. Lex sorride — ha vinto lui."
                },
                {
                  "id": "disegno_visto_b_t2",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Sembrano... capelli che brillano. Come quelli del video."
                },
                {
                  "id": "disegno_visto_b_t3",
                  "type": "narration",
                  "text": "Il silenzio dura un secondo. Lex guarda Mallow. Mallow guarda Favilla. Favilla guarda il foglio appallottolato."
                },
                {
                  "id": "disegno_visto_b_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Ha collegato il disegno al video. Mio figlio mi ha appena fregato. Con un pastello."
                }
              ]
            }
          ],
          "id": "bdiseg_p1"
        }
      ]
    }
  },
