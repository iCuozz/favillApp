        }
      ]
    }
  ],
  "branches": {
    "intro_precaria": {
      "id": "intro_precaria",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "intro_precaria_a",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "intro_precaria_a_t1",
                  "type": "narration",
                  "text": "Favilla is on the couch. Phone in hand, screen off. She hasn't been able to sleep for hours."
                },
                {
                  "id": "intro_precaria_a_t2",
                  "type": "narration",
                  "text": "The secret weighs. Every passing day is another brick. And the house feels it."
                },
                {
                  "id": "intro_precaria_a_t3",
                  "type": "narration",
                  "text": "From the playpen, Lex watches her. He can't sleep either. He has the face of someone who wants to help but doesn't know how."
                },
                {
                  "id": "intro_precaria_a_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "You're awake too. You feel it too. Sorry, little one."
                }
              ]
            }
          ],
          "id": "ipreca_p0"
        }
      ]
    },
    "branch_svolta": {
      "id": "branch_svolta",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "branch_svolta_a",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "branch_svolta_a_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "I can't explain it. But trust me. Please."
                },
                {
                  "id": "branch_svolta_a_t2",
                  "type": "narration",
                  "text": "Mallow looks at her for a long time. Then nods — slowly, as if every millimeter of that nod costs immense effort."
                },
                {
                  "id": "branch_svolta_a_t3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "I trust you. I've always trusted you. But trusting and understanding are two different things."
                },
                {
                  "id": "branch_svolta_a_t4",
                  "type": "narration",
                  "text": "Lex, from the playpen, opens his mouth as if to say something. Then closes it. Straightens the owl plushie. He's decided: for tonight, he'll let it go."
                }
              ]
            }
          ],
          "id": "bsvolt_p0"
        }
      ]
    },
    "branch_silenzio": {
      "id": "branch_silenzio",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "branch_silenzio_a",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "branch_silenzio_a_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Let it go. I'm just tired."
                },
                {
                  "id": "branch_silenzio_a_t2",
                  "type": "narration",
                  "text": "Mallow says nothing. She's been 'tired' for weeks. He knows it's a lie. But he has no energy left to chase it."
                },
                {
                  "id": "branch_silenzio_a_t3",
                  "type": "narration",
                  "text": "He folds the burned shirt. Puts it in a drawer. Doesn't throw it away — keeps it."
                },
                {
                  "id": "branch_silenzio_a_t4",
                  "type": "narration",
                  "text": "Lex watches the scene from the playpen. Then closes his eyes. He's stopped waiting. For tonight."
                }
              ]
            }
          ],
          "id": "bsilen_p0"
        }
      ]
    },
    "branch_crepa_quasi_vera": {
      "id": "branch_crepa_quasi_vera",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "crepa_vera_a",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "crepa_vera_a_t1",
                  "type": "narration",
                  "text": "Favilla speaks. The words come out one after another, without the filter that's kept them safe for weeks."
                },
                {
                  "id": "crepa_vera_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "That night in the kitchen... when Lex was about to fall. Something happened. I... I wasn't me anymore."
                },
                {
                  "id": "crepa_vera_a_t3",
                  "type": "narration",
                  "text": "Mallow listens. He doesn't interrupt. He doesn't say 'what do you mean' — he waits."
                },
                {
                  "id": "crepa_vera_a_t4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "My hair. It lit up. As if... I don't know. As if I had the sun inside."
                },
                {
                  "id": "crepa_vera_a_t5",
                  "type": "narration",
                  "text": "Silence. Mallow doesn't understand. But he doesn't laugh. He doesn't judge."
                }
              ]
            }
          ],
          "id": "bcrepa_p0"
        },
        {
          "background": "assets/episodes/prologo/page_4.png",
          "panels": [
            {
              "id": "crepa_vera_b",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "crepa_vera_b_t1",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "You're saying... that night something really strange happened? You didn't imagine it?"
                },
                {
                  "id": "crepa_vera_b_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "I didn't imagine it. Lex saw it. That's why he looks at me like that."
                },
                {
                  "id": "crepa_vera_b_t3",
                  "type": "narration",
                  "text": "From the playpen, Lex makes a sound. Not loud. But present. As if to say: 'yes, it's true'."
                },
                {
                  "id": "crepa_vera_b_t4",
                  "type": "narration",
                  "text": "Mallow looks at Lex. Then Favilla. He doesn't know what to think. But for the first time, he doesn't ask her to prove it."
                }
              ]
            }
          ],
          "id": "bcrepa_p1"
        }
      ]
    },
    "branch_crepa_sfumata": {
      "id": "branch_crepa_sfumata",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "crepa_sfumata_a",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "crepa_sfumata_a_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "That Sunday at the park... I didn't tell you everything. There were things... strange things."
                },
                {
                  "id": "crepa_sfumata_a_t2",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Strange how?"
                },
                {
                  "id": "crepa_sfumata_a_t3",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Like... I don't know. Like time skipped a beat. And I was faster."
                },
                {
                  "id": "crepa_sfumata_a_t4",
                  "type": "narration",
                  "text": "Mallow furrows his brow. He's not satisfied. But it's something. More than he had before."
                },
                {
                  "id": "crepa_sfumata_a_t5",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Okay. I don't understand. But okay. We'll talk tomorrow."
                }
              ]
            }
          ],
          "id": "bcrepa_p0"
        }
      ]
    },
    "branch_crepa_bloccata": {
      "id": "branch_crepa_bloccata",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "crepa_bloccata_a",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "crepa_bloccata_a_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Mallow... I..."
                },
                {
                  "id": "crepa_bloccata_a_t2",
                  "type": "narration",
                  "text": "Nothing. It won't come out. Her mouth is dry. The words are there, behind her tongue, but they can't jump."
                },
                {
                  "id": "crepa_bloccata_a_t3",
                  "type": "narration",
                  "text": "Mallow waits. Then stops waiting."
                },
                {
                  "id": "crepa_bloccata_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Okay. Whenever you're ready."
                },
                {
                  "id": "crepa_bloccata_a_t5",
                  "type": "narration",
                  "text": "He doesn't say it with sweetness. He says it with tiredness. The same tiredness Favilla has felt for weeks."
                }
              ]
            }
          ],
          "id": "bcrepa_p0"
        }
      ]
    }
  },
  "epilogue": {
    "id": "epilogue",
    "pages": [
      {
        "background": "assets/episodes/prologo/page_4.png",
        "panels": [
          {
            "id": "cr_epilogo_a",
            "characters": [
              "favilla"
            ],
            "text_blocks": [
              {
                "id": "cr_epilogo_a_t1",
                "type": "narration",
                "text": "Favilla goes back to the bedroom. Mallow is turned the other way. He's not asleep — but he's pretending."
              },
              {
                "id": "cr_epilogo_a_t2",
                "type": "narration",
                "text": "Lex sleeps. He's clutching the owl plushie. His plan worked — dad knows something's there — but there's no victory on his face. Just sleep."
              },
              {
                "id": "cr_epilogo_a_t3",
                "type": "thought",
                "speaker": "favilla",
                "text": "The secret is intact. But the crack is there. And tomorrow will be another day — with a family that knows it doesn't know."
              }
            ]
          }
        ],
        "id": "ep_p0"
      },
      {
        "background": "assets/episodes/prologo/page_carmela.png",
        "panels": [
          {
            "id": "cr_epilogo_b",
            "characters": [
              "carmela"
            ],
            "text_blocks": [
              {
                "id": "cr_epilogo_b_t1",
                "type": "narration",
                "text": "On the other side of the street, a light turns on. One second. Then it turns off."
              },
              {
                "id": "cr_epilogo_b_t2",
                "type": "narration",
                "text": "Carmela was awake. She felt something. She doesn't know what. But she'll feel it again."
              }
            ]
          }
        ],
        "id": "ep_p1"
      }
    ]
  }
}