                },
                "set_memories": {
                  "choice.s1_crepa": "svolta"
                }
              },
              {
                "id": "silenzio",
                "label": "\"Let it go. I'm just tired.\"",
                "goto_branch": "branch_silenzio",
                "stat_effects": {
                  "segreto": 5,
                  "legame": -8,
                  "resistenza": -3
                },
                "set_flags": {
                  "crepa_silenzio": true
                },
                "set_memories": {
                  "choice.s1_crepa": "silenzio"
                }
              },
              {
                "id": "quasi_confessa",
                "label": "\"Maybe... I need to tell you something.\"",
                "goto_branch": "branch_crepa_bloccata",
                "stat_effects": {
                  "segreto": -8,
                  "legame": 10,
                  "resistenza": 3
                },
                "set_memories": {
