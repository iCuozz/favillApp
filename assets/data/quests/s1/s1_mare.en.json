              }
            ]
          }
        }
      ]
    },
    "branch_preso_bene": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_lex_preso.webp",
          "panels": [
            {
              "id": "bpb_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                { "id": "bpb_0_tb_0", "type": "narration", "text": "Caught in time. Lex emits a solemn protest — then finds a shell and forgets everything else." },
                { "id": "bpb_0_tb_1", "type": "dialogue", "speaker": "favilla", "text": "\"Quick as lightning, aren't you.\"" },
                { "id": "bpb_0_tb_2", "type": "narration", "text": "Lex doesn't answer. He's already analysing the shell with the same intensity he was just applying to the sea." }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_quasi_visto": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_lex_preso.webp",
          "panels": [
            {
              "id": "bqv_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                { "id": "bqv_0_tb_0", "type": "narration", "text": "Caught — but the lady with the straw hat saw something. Or thinks she saw something." },
                { "id": "bqv_0_tb_1", "type": "narration", "text": "Favilla smiles — that generic beach smile that says 'kids, eh' — and the lady nods, not entirely convinced." },
                { "id": "bqv_0_tb_2", "type": "narration", "text": "Lex winks at the lady. The lady doesn't know what she saw. Lex does." }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_momento_magico": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_tramonto_riva.webp",
          "panels": [
            {
              "id": "bmm_0",
              "characters": ["favilla", "lex", "mallow"],
              "text_blocks": [
                { "id": "bmm_0_tb_0", "type": "narration", "text": "Favilla catches him right at the water's edge — cold foam at her feet, Lex lifted and laughing." },
                { "id": "bmm_0_tb_1", "type": "narration", "text": "Sunset light. Favilla's hair — for just a second, only a second — has a tint that isn't only the orange of the sun." },
                { "id": "bmm_0_tb_2", "type": "narration", "text": "Mallow watches her from a distance. He thinks: she's beautiful." },
                { "id": "bmm_0_tb_3", "type": "narration", "text": "He doesn't understand. Not yet. But this moment he photographs with his eyes and won't throw away." }
              ],
              "interactions": []
            }
          ]
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "index": 0,
        "background": "assets/episodes/s1/s1_mare/page_tramonto.webp",
        "panels": [
          {
            "id": "ep_sm_0",
            "characters": ["favilla", "mallow", "lex"],
            "text_blocks": [
              { "id": "ep_sm_0_tb_0", "type": "narration", "text": "Sunset. Lex asleep on Mallow's chest, small hand gripping his jumper." },
              { "id": "ep_sm_0_tb_1", "type": "narration", "text": "The sea makes that sound. The one that never stops." }
            ],
            "interactions": []
          }
        ]
      },
      {
        "index": 1,
        "background": "assets/episodes/s1/s1_mare/page_tramonto.webp",
        "panels": [
          {
            "id": "ep_sm_1",
            "characters": ["favilla", "mallow"],
            "text_blocks": [
              { "id": "ep_sm_1_tb_0", "type": "narration", "text": "Mallow takes her hand without looking." },
              { "id": "ep_sm_1_tb_1", "type": "dialogue", "speaker": "mallow", "text": "\"Thank you for coming.\"" },
              { "id": "ep_sm_1_tb_2", "type": "narration", "text": "Not 'thank you for telling me you weren't well.' Just: thank you for coming. As if that were enough." },
              { "id": "ep_sm_1_tb_3", "type": "narration", "text": "As if, maybe, it really was." }
            ],
            "interactions": []
          }
        ]
      },
      {
        "index": 2,
        "background": "assets/episodes/s1/s1_mare/page_gatto_lungomare.webp",
        "panels": [
          {
            "id": "ep_sm_2",
            "characters": ["gatto"],
            "text_blocks": [
              { "id": "ep_sm_2_tb_0", "type": "narration", "text": "On the promenade, sitting on a low wall — the cat." },
              { "id": "ep_sm_2_tb_1", "type": "narration", "text": "Yellow eyes watching the family as if taking notes." },
              { "id": "ep_sm_2_tb_2", "type": "narration", "text": "Then it stands, turns its tail. Heading for number 19, third floor." }
            ],
            "interactions": []
          }
        ],
        "choice": {
          "id": "fine_mare",
          "prompt": "The sea works.",
          "options": [
            {
              "id": "torna_casa",
              "label": "The sea works.",
              "goto_branch": "",
              "stat_effects": { "resistenza": 20 }
            }
          ]
        }
      }
    ]
  }
}
