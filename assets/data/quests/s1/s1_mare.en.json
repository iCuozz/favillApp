  ],
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/s1/s1_mare/page_0.webp",
      "panels": [
        {
          "id": "sm0_0",
          "characters": ["favilla", "mallow", "lex"],
          "text_blocks": [
            { "id": "sm0_0_tb_0", "type": "narration", "text": "The beach umbrella takes seventeen minutes and three Italian-technical instructions to set up." },
            { "id": "sm0_0_tb_1", "type": "narration", "text": "Mallow manages it, with Lex in the carrier supervising every move with extreme seriousness." },
            { "id": "sm0_0_tb_2", "type": "narration", "text": "Favilla lies down on the deck chair. Closes her eyes." },
            { "id": "sm0_0_tb_3", "type": "thought", "text": "For two whole seconds — a personal record in weeks — she thinks about nothing." }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_mare/page_1.webp",
      "panels": [
        {
          "id": "sm1_0",
          "characters": ["favilla", "mallow"],
          "text_blocks": [
            { "id": "sm1_0_tb_0", "type": "narration", "text": "Mallow comes back from the beach bar with a cold water bottle — and a coffee." },
            { "id": "sm1_0_tb_1", "type": "narration", "text": "He places it on the plastic side table, next to Favilla's hand." },
            { "id": "sm1_0_tb_2", "type": "dialogue", "speaker": "mallow", "text": "\"I brought you a coffee too. But if you don't want it, that's fine.\"" },
            { "id": "sm1_0_tb_3", "type": "narration", "text": "He waits, watching her. He doesn't insist. He never does." }
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "caffe_choice",
        "prompt": "The coffee is right there. Hot. Familiar.",
        "options": [
          {
            "id": "prende_caffe",
            "label": "She takes it.",
            "goto_branch": "branch_caffe_si",
            "stat_effects": { "scintille": 15, "resistenza": -10, "legame": 10 }
          },
          {
            "id": "lascia_caffe",
            "label": "She leaves it there.",
            "goto_branch": "branch_caffe_no",
            "stat_effects": { "resistenza": 10, "legame": -5 }
          }
        ]
      }
    }
  ],
  "branches": {
    "intro_mallow_sa_qualcosa": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_intro_mallow.webp",
          "panels": [
            {
              "id": "imq_0",
              "characters": ["favilla", "mallow"],
              "text_blocks": [
                { "id": "imq_0_tb_0", "type": "narration", "text": "In the car, Mallow drives slowly. At the traffic light, he says just one thing." },
                { "id": "imq_0_tb_1", "type": "dialogue", "speaker": "mallow", "text": "\"At the park the other day... I was scanning for Lex and for a second I couldn't find you. Then you were there again.\"" },
                { "id": "imq_0_tb_2", "type": "narration", "text": "A pause. He doesn't add anything. Favilla stares out the window. She doesn't know what to say — so she says nothing." },
                { "id": "imq_0_tb_3", "type": "narration", "text": "It's not a question. It's a fact he's decided to put into the world." }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "intro_esausta": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_intro_esausta.webp",
          "panels": [
            {
              "id": "ie_0",
              "characters": ["favilla"],
              "text_blocks": [
                { "id": "ie_0_tb_0", "type": "narration", "text": "In the car, Favilla sleeps. She doesn't even notice — head against the window, eyes closed, hair ruffled by the air conditioning." },
                { "id": "ie_0_tb_1", "type": "narration", "text": "She wakes up when they smell the salt." },
                { "id": "ie_0_tb_2", "type": "narration", "text": "And when Lex makes a sound he's never made before — something between a shriek and a revelation." }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "intro_mani_calde": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_intro_mani.webp",
          "panels": [
            {
              "id": "imc_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                { "id": "imc_0_tb_0", "type": "narration", "text": "Already in the car, Favilla's hands on the dashboard are warm. Like always, lately." },
                { "id": "imc_0_tb_1", "type": "narration", "text": "As if the heat never stopped looking for her." },
                { "id": "imc_0_tb_2", "type": "narration", "text": "Lex watches her with that expression he has — like he's taking notes." }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_caffe_si": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_caffe.webp",
          "panels": [
            {
              "id": "bcs_0",
              "characters": ["favilla", "mallow", "lex"],
              "text_blocks": [
                { "id": "bcs_0_tb_0", "type": "narration", "text": "She takes it. Drinks it in one sip. Hot, strong, familiar." },
                { "id": "bcs_0_tb_1", "type": "narration", "text": "Mallow smiles — that small smile he always has ready for her." },
                { "id": "bcs_0_tb_2", "type": "narration", "text": "Lex watches her drink. His eyes move from the coffee to Favilla's hair. From the coffee to her hair. An expression of updated calculations — and approved." }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 1,
          "background": "assets/episodes/s1/s1_mare/page_lex_acqua.webp",
          "panels": [
            {
              "id": "bcs_1",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                { "id": "bcs_1_tb_0", "type": "narration", "text": "He's been on the towel for three minutes when he spots the target." },
                { "id": "bcs_1_tb_1", "type": "narration", "text": "The sea. Big. Glittering. Like Mum — that time." },
                { "id": "bcs_1_tb_2", "type": "narration", "text": "He starts moving." }
              ],
              "interactions": []
            }
          ],
          "choice": {
            "id": "distrai_lex_choice_si",
            "prompt": "Lex is heading for the water.",
            "options": [
              {
                "id": "distrai_lex_si",
                "label": "Distract him before he gets there!",
                "goto_branch": "branch_preso_bene",
                "stat_effects": {},
                "minigame": {
                  "type": "rincorsa_lex",
                  "duration_seconds": 15,
                  "tiers": [
                    { "min": 5, "label": "Got him!", "goto_branch": "branch_preso_bene", "stat_effects": { "resistenza": 10, "legame": 5 } },
                    { "min": 3, "label": "Almost...", "goto_branch": "branch_quasi_visto", "stat_effects": { "segreto": -8, "legame": 5 } },
                    { "min": 0, "label": "Sunset.", "goto_branch": "branch_momento_magico", "stat_effects": { "segreto": -5, "legame": 15, "resistenza": 5 } }
                  ]
                }
              }
            ]
          }
        }
      ]
    },
    "branch_caffe_no": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_mare/page_caffe.webp",
          "panels": [
            {
              "id": "bcn_0",
              "characters": ["favilla", "mallow", "lex"],
              "text_blocks": [
                { "id": "bcn_0_tb_0", "type": "dialogue", "speaker": "favilla", "text": "\"Not today.\"" },
                { "id": "bcn_0_tb_1", "type": "narration", "text": "Mallow doesn't blink. He takes the coffee himself and finishes it unhurriedly, watching the sea." },
                { "id": "bcn_0_tb_2", "type": "narration", "text": "Lex looks at Mallow's coffee. Then at Favilla. Then back at the coffee. An expression of revised calculations — not abandoned ones." }
              ],
              "interactions": []
            }
          ]
        },
        {
          "index": 1,
          "background": "assets/episodes/s1/s1_mare/page_lex_acqua.webp",
          "panels": [
            {
              "id": "bcn_1",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                { "id": "bcn_1_tb_0", "type": "narration", "text": "He's been on the towel for three minutes when he spots the target." },
                { "id": "bcn_1_tb_1", "type": "narration", "text": "The sea. Big. Glittering. Like Mum — that time." },
                { "id": "bcn_1_tb_2", "type": "narration", "text": "He starts moving." }
              ],
              "interactions": []
            }
          ],
          "choice": {
