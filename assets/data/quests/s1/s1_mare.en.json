                "id": "distrai_lex_no",
                "label": "Distract him before he gets there!",
                "goto_branch": "branch_preso_bene",
                "stat_effects": {},
                "minigame": {
                  "type": "rincorsa_lex",
                  "duration_seconds": 15,
                  "tiers": [
                    { "min": 5, "label": "Got him!", "goto_branch": "branch_preso_bene", "stat_effects": { "resistenza": 10, "legame": 5 } },
                    { "min": 3, "label": "Almost...", "goto_branch": "branch_quasi_visto", "stat_effects": { "segreto": -8, "legame": 5 } },
                    { "min": 0, "label": "Sunset.", "goto_branch": "branch_momento_magico", "stat_effects": { "segreto": -5, "legame": 15, "resistenza": 5 } }
                  ]
