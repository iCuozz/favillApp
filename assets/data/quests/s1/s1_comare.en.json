    }
  ],
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/prologo/page_1.png",
      "panels": [
        {
          "id": "comare_p0_a",
          "characters": [
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "comare_p0_a_t1",
              "type": "narration",
              "text": "Afternoon. Mallow is out on an errand. Lex dozes in the playpen. Favilla has ten minutes of silence."
            },
            {
              "id": "comare_p0_a_t2",
              "type": "narration",
              "text": "Then the doorbell rings. Once. Brief. Precise."
            },
            {
              "id": "comare_p0_a_t3",
              "type": "narration",
              "text": "Favilla looks through the peephole. Carmela. Straw hat. An envelope in hand. Smiling."
            },
            {
              "id": "comare_p0_a_t4",
              "type": "thought",
              "speaker": "favilla",
              "text": "No. Not today. Not today."
            }
          ]
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/prologo/page_2.png",
      "panels": [
        {
          "id": "comare_p1_a",
          "characters": [
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "comare_p1_a_t1",
              "type": "narration",
              "text": "Through the peephole, Carmela is motionless. The envelope has the Bellow family's name, the downstairs neighbors."
            },
            {
              "id": "comare_p1_a_t2",
              "type": "dialogue",
              "speaker": "carmela",
              "text": "Mrs. Bellow? They delivered your mail wrong. They left it at my place."
            },
            {
              "id": "comare_p1_a_t3",
              "type": "narration",
              "text": "Lex opens his eyes. He doesn't cry. He doesn't laugh. He stares at the door."
            },
            {
              "id": "comare_p1_a_t4",
              "type": "thought",
              "speaker": "favilla",
              "text": "Lex. Lex stopped laughing. And that scares me more than Carmela."
            }
          ],
          "choice": {
            "id": "porta_choice",
            "prompt": "Carmela has an envelope. And a smile you don't like.",
            "options": [
              {
                "id": "apri",
                "label": "Open the door. Let her in.",
                "goto_branch": "branch_apre",
                "stat_effects": {
                  "segreto": -5,
                  "resistenza": -5
                },
                "set_memories": {
                  "choice.s1_comare.porta": "aperta"
                }
              },
              {
                "id": "tieni_chiuso",
                "label": "\"Thanks, just leave it in the mail slot!\"",
                "goto_branch": "branch_non_apre",
                "stat_effects": {
                  "segreto": 8,
                  "legame": -5
                },
                "set_flags": {
                  "carmela_respinta": true
                },
                "set_memories": {
                  "choice.s1_comare.porta": "chiusa"
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "branches": {
    "intro_sola": {
      "id": "intro_sola",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "intro_sola_a",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "intro_sola_a_t1",
                  "type": "narration",
                  "text": "Favilla is alone in the living room. Mallow is at work. Lex is asleep. The silence is deafening."
                },
                {
                  "id": "intro_sola_a_t2",
                  "type": "narration",
                  "text": "It's been days since she's really talked to anyone. Mallow tries to ask, but she deflects. She's gotten good at deflecting."
                },
                {
                  "id": "intro_sola_a_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Maybe it's better this way. Alone. Safer. More... everything."
                },
                {
                  "id": "intro_sola_a_t4",
                  "type": "narration",
                  "text": "Then the doorbell rings. And everything gets worse."
                }
              ]
            }
          ],
          "id": "isola_p0"
        }
      ]
    },
    "intro_segreto_rivelazione": {
      "id": "intro_segreto_rivelazione",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "isr_comare_a",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "isr_comare_a_t1",
                  "type": "narration",
                  "text": "Favilla is on the couch. Ten minutes of silence. But it's not real silence — it's the kind of quiet where every sound from the building makes you flinch."
                },
                {
                  "id": "isr_comare_a_t2",
                  "type": "narration",
                  "text": "The secret is so fragile it almost burns inside her. Every time Mallow looks at her, every time Lex makes a weird sound, every time the phone rings — her heart races."
                },
                {
                  "id": "isr_comare_a_t3",
                  "type": "narration",
                  "text": "She feels watched even when she's alone. Because maybe she's never alone. Not anymore."
                },
                {
                  "id": "isr_comare_a_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "I can't make any more mistakes. Every word, every gesture. One wrong move and everything collapses — Mallow, Lex, normalcy. Everything."
                }
              ]
            }
          ],
          "id": "isr_comare_p0"
        },
        {
          "background": "assets/episodes/prologo/page_carmela.png",
          "panels": [
            {
              "id": "isr_comare_b",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "isr_comare_b_t1",
                  "type": "narration",
                  "text": "Then the doorbell rings. Once. Brief. Precise."
                },
                {
                  "id": "isr_comare_b_t2",
                  "type": "narration",
                  "text": "Favilla already knows who it is. She feels it — literally. A hum under her skin, as if something is pulling the thread the secret hangs from."
                },
                {
                  "id": "isr_comare_b_t3",
                  "type": "narration",
                  "text": "Carmela couldn't have picked a worse moment. Or a better one — for her."
                },
                {
                  "id": "isr_comare_b_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "She knows I'm fragile. She can smell it. And I'm about to open that door."
                }
              ]
            }
          ],
          "id": "isr_comare_p1"
        }
      ]
    },
    "branch_apre": {
      "id": "branch_apre",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_apre_a",
              "characters": [
                "favilla",
                "carmela",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_apre_a_t1",
                  "type": "narration",
                  "text": "Favilla opens the door. Carmela enters with the calm of someone who has crossed that threshold a thousand times. Even though it's the first."
                },
                {
                  "id": "branch_apre_a_t2",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "What a cozy home. Warm. Like you."
                },
                {
                  "id": "branch_apre_a_t3",
                  "type": "narration",
                  "text": "She looks around. Not like someone admiring décor. Like someone taking notes."
                },
                {
                  "id": "branch_apre_a_t4",
                  "type": "narration",
                  "text": "Lex in the playpen is motionless. His eyes follow Carmela as if she were a predator. He's never looked at anyone like this."
                }
              ]
            }
          ],
          "id": "bapre_p0"
        },
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "branch_apre_b",
              "characters": [
                "favilla",
                "carmela"
              ],
              "text_blocks": [
                {
                  "id": "branch_apre_b_t1",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "Listen. Can I ask you something? It's funny. The other day at the supermarket..."
                },
                {
                  "id": "branch_apre_b_t2",
                  "type": "narration",
                  "text": "Favilla feels something. A hum. Under her skin. Like when the Sparks activate, but in reverse. As if something were draining her heat."
                },
                {
                  "id": "branch_apre_b_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "She's not a neighbor. She's a sensor. And she's reading me."
                }
              ],
              "choice": {
                "id": "carmela_dialogo_choice",
                "prompt": "Carmela probes. Every word is a hook.",
                "options": [
                  {
                    "id": "affronta_carmela",
                    "label": "Answer. Calmly.",
                    "stat_effects": {
                      "segreto": -5,
                      "resistenza": -5
                    },
                    "minigame": {
                      "type": "carmela_dialogo",
                      "extra": {
                        "questions": [
                          {
                            "text": "\"Such peace in here. You wouldn't tell from outside. There's something different about you, Favilla.\"",
                            "timer": 4.0,
                            "options": [
                              {
                                "label": "\"Thanks, I tidied up last week.\"",
                                "safe": true
                              },
                              {
                                "label": "\"I've been feeling good, lately.\"",
                                "safe": true
                              },
                              {
                                "label": "\"Different how?\"",
                                "safe": false
                              }
                            ],
                            "timeout_index": 2
                          },
                          {
                            "text": "\"It's funny, the other day I heard a strange noise from your floor. It was late.\"",
                            "timer": 3.5,
                            "options": [
                              {
                                "label": "\"Oh, it was probably Lex playing on the floor.\"",
                                "safe": true
                              },
                              {
                                "label": "\"I didn't hear anything, maybe I was asleep.\"",
                                "safe": true
                              },
                              {
                                "label": "\"What time was it? What kind of noise?\"",
                                "safe": false
                              }
                            ],
                            "timeout_index": 2
                          },
                          {
                            "text": "\"That Sunday at the park — was that really you? I swear, I smelled something burning.\"",
                            "timer": 3.0,
                            "options": [
                              {
                                "label": "\"Probably a barbecue. There were lots of people.\"",
                                "safe": true
                              },
                              {
                                "label": "\"The park is big, it could have been anyone.\"",
                                "safe": true
                              },
                              {
                                "label": "\"I don't know what you're talking about.\"",
                                "safe": false
                              }
                            ],
                            "timeout_index": 2
                          },
                          {
                            "text": "\"I spend a lot of time on the terrace in the evening. Your living room windows... sometimes there's a strange light.\"",
                            "timer": 2.5,
                            "options": [
                              {
                                "label": "\"Must be Mallow's TV, he keeps the monitor on late.\"",
                                "safe": true
                              },
                              {
                                "label": "\"Mallow works late on his computer, probably the reflection.\"",
                                "safe": true
                              },
                              {
                                "label": "\"What did you see? Exactly?\"",
                                "safe": false
                              }
                            ],
                            "timeout_index": 2
                          }
                        ]
                      },
                      "tiers": [
                        {
                          "min": 3,
                          "label": "Unshakeable.",
                          "goto_branch": "branch_carmela_bene",
                          "stat_effects": {
                            "segreto": 10,
                            "resistenza": 5
                          }
                        },
                        {
                          "min": 1,
                          "label": "Wobbly.",
                          "goto_branch": "branch_carmela_quasi",
                          "stat_effects": {
                            "segreto": -5,
                            "legame": -3
                          }
                        },
                        {
                          "min": 0,
                          "label": "Exposed.",
                          "goto_branch": "branch_carmela_disastro",
                          "stat_effects": {
                            "segreto": -15,
                            "legame": -8
                          },
                          "set_flags": {
                            "carmela_segno": true
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ],
          "id": "bapre_p1"
        }
      ]
    },
    "branch_non_apre": {
      "id": "branch_non_apre",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "branch_non_apre_a",
              "characters": [
                "favilla",
                "carmela",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_non_apre_a_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Thanks, just leave it in the mail slot! I'm in the shower!"
                },
                {
                  "id": "branch_non_apre_a_t2",
                  "type": "narration",
                  "text": "Silence. Then the rustle of the envelope slipping through the slot. Then Carmela's footsteps walking away. Slow. Too slow."
                },
                {
                  "id": "branch_non_apre_a_t3",
                  "type": "narration",
                  "text": "Favilla holds her breath. Lex watches her from the playpen. He understood."
                },
                {
                  "id": "branch_non_apre_a_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "Not opening was the right choice. But she knows I'm afraid. And fear is what she's looking for."
                }
              ]
            }
          ],
          "id": "bnon_a_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_non_apre_b",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "branch_non_apre_b_t1",
                  "type": "narration",
                  "text": "Favilla waits ten seconds. Then goes to the door. The envelope is there — actually addressed to the Bellows."
                },
                {
                  "id": "branch_non_apre_b_t2",
                  "type": "narration",
                  "text": "Maybe it was a real excuse. Maybe not. With Carmela you can never know."
                },
                {
                  "id": "branch_non_apre_b_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "She'll be back. I gave her what she wanted: proof that I'm hiding."
                }
              ]
            }
          ],
          "id": "bnon_a_p1"
        }
      ]
    },
    "branch_carmela_bene": {
      "id": "branch_carmela_bene",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "branch_carmela_bene_a",
              "characters": [
                "favilla",
                "carmela"
              ],
              "text_blocks": [
                {
                  "id": "branch_carmela_bene_a_t1",
                  "type": "narration",
                  "text": "Carmela smiles. But it's a different smile — she didn't find what she was looking for."
                },
                {
                  "id": "branch_carmela_bene_a_t2",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "Well, I'll let you rest. It was just the mail."
                },
                {
                  "id": "branch_carmela_bene_a_t3",
                  "type": "narration",
                  "text": "She turns toward the door. Hesitates for a second. Then leaves. Favilla closes the door and leans against it. Breathes."
                },
                {
                  "id": "branch_carmela_bene_a_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "She didn't find anything. Or so she thinks. I dodged it. For now."
                }
              ]
            }
          ],
          "id": "bcarme_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_carmela_bene_b",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_carmela_bene_b_t1",
                  "type": "narration",
                  "text": "Lex has started playing again. Carmela is gone and he's back to normal. As if the danger has passed."
                },
                {
                  "id": "branch_carmela_bene_b_t2",
                  "type": "narration",
                  "text": "Favilla picks him up. He touches her hair. No heat. No Spark. Just mom and baby."
                }
              ]
            }
          ],
          "id": "bcarme_p1"
        }
      ]
    },
    "branch_carmela_quasi": {
      "id": "branch_carmela_quasi",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "branch_carmela_quasi_a",
              "characters": [
                "favilla",
                "carmela"
              ],
              "text_blocks": [
                {
                  "id": "branch_carmela_quasi_a_t1",
                  "type": "narration",
                  "text": "Carmela stands up. The tea is still warm. She smiles — a smile that doesn't reach her eyes."
                },
                {
                  "id": "branch_carmela_quasi_a_t2",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "You're always so vibrant, Favilla. That's all. Don't be offended."
                },
                {
                  "id": "branch_carmela_quasi_a_t3",
                  "type": "narration",
                  "text": "At the door, she stops. Doesn't turn around."
                },
                {
                  "id": "branch_carmela_quasi_a_t4",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "Oh, I forgot. Come visit me sometime, when you can. I'd like that."
                }
              ]
            }
          ],
          "id": "bcarme_p0"
        },
        {
          "background": "assets/episodes/prologo/page_1.png",
          "panels": [
            {
              "id": "branch_carmela_quasi_b",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_carmela_quasi_b_t1",
                  "type": "narration",
                  "text": "The door closes. Favilla stares at the wood. 'Come visit me.' It wasn't an invitation. It was a summons."
                },
                {
                  "id": "branch_carmela_quasi_b_t2",
                  "type": "narration",
                  "text": "Lex from the playpen watches the door. Then watches Favilla. He has the same expression as when he almost hacked the notebook."
                },
                {
                  "id": "branch_carmela_quasi_b_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "She sniffed me. She doesn't know what it is, but she knows something's there."
                }
              ]
            }
          ],
          "id": "bcarme_p1"
        }
      ]
    },
    "branch_carmela_disastro": {
      "id": "branch_carmela_disastro",
      "pages": [
        {
          "background": "assets/episodes/prologo/page_2.png",
          "panels": [
            {
              "id": "branch_carmela_disastro_a",
              "characters": [
                "favilla",
                "carmela"
              ],
              "text_blocks": [
                {
                  "id": "branch_carmela_disastro_a_t1",
                  "type": "narration",
                  "text": "Carmela isn't smiling anymore. She stands up. Gets closer. Too close."
                },
                {
                  "id": "branch_carmela_disastro_a_t2",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "You carry something big inside you. I can feel it."
                },
                {
                  "id": "branch_carmela_disastro_a_t3",
                  "type": "narration",
                  "text": "Favilla feels the hum increase. As if Carmela is draining something from her. Her hair quivers — just once, imperceptibly."
                },
                {
                  "id": "branch_carmela_disastro_a_t4",
                  "type": "narration",
                  "text": "Carmela notices. She says nothing. But she notices."
                }
              ]
            }
          ],
          "id": "bcarme_p0"
        },
        {
          "background": "assets/episodes/prologo/page_3.png",
          "panels": [
            {
              "id": "branch_carmela_disastro_b",
              "characters": [
                "favilla",
                "carmela",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_carmela_disastro_b_t1",
                  "type": "narration",
                  "text": "At the door, Carmela turns around. Lex stares at her from the playpen. He hasn't looked away. Not once."
                },
                {
                  "id": "branch_carmela_disastro_b_t2",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "What a bright child. He... feels it too, doesn't he?"
                },
                {
                  "id": "branch_carmela_disastro_b_t3",
                  "type": "narration",
                  "text": "She leaves. The door closes. Favilla looks at Lex. Lex looks at the door. Something has changed."
                },
                {
                  "id": "branch_carmela_disastro_b_t4",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "She left a mark. I don't know what. But it's in here. And she never really left."
                }
              ]
            }
          ],
          "id": "bcarme_p1"
        }
      ]
    }
  },
  "epilogue": {
    "id": "epilogue",
    "pages": [
      {
        "background": "assets/episodes/prologo/page_4.png",
        "panels": [
          {
            "id": "comare_epilogue_a",
            "characters": [
              "favilla"
            ],
            "text_blocks": [
              {
                "id": "comare_epilogue_a_t1",
                "type": "narration",
                "text": "Favilla is in the kitchen. The Bellows' envelope is on the table. She still hasn't delivered it."
              },
              {
                "id": "comare_epilogue_a_t2",
                "type": "narration",
                "text": "Maybe Carmela never brought it for the Bellows. Maybe it was always an excuse. Maybe nothing is ever what it seems with her."
              },
              {
                "id": "comare_epilogue_a_t3",
                "type": "narration",
                "text": "Lex sleeps in the playpen. Restless sleep. As if dreaming of something dark."
              },
              {
                "id": "comare_epilogue_a_t4",
                "type": "system",
                "text": "MISSION COMPLETE — The Nosy Neighbor"
              }
            ]
          }
        ],
        "id": "ep_p0"
      }
    ]
  }
}