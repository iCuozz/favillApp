{
  "id": "s1_prima_conseguenza",
  "audio_theme": "scuola_pressure",
  "stat_entry": [
    {
      "flag_conditions": [
        {
          "flag": "video_virale_visto",
          "is": true
        }
      ],
      "goto_branch": "intro_gia_visto",
      "prepend": true
    }
  ],
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/s1/s1_prima_conseguenza/page_0.webp",
      "panels": [
        {
          "id": "pc_p0_a",
          "characters": [
            "favilla",
            "mallow",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "pc_p0_a_t1",
              "type": "narration",
              "text": "Home. Afternoon. Lex plays on the rug with the GalaxiaMall owl plushie. Favilla folds laundry. Everything normal."
            },
            {
              "id": "pc_p0_a_t2",
              "type": "narration",
              "text": "Then Mallow comes out of the study with his phone in hand. He has the expression of someone who just saw something he wasn't supposed to see."
            },
            {
              "id": "pc_p0_a_t3",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Hey. Have you seen this?"
            },
            {
              "id": "pc_p0_a_t4",
              "type": "narration",
              "text": "Lex looks up from the owl plushie. He noticed Mallow's tone too. That tone."
            }
          ]
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_prima_conseguenza/page_1.webp",
      "panels": [
        {
          "id": "pc_p1_a",
          "characters": [
            "favilla",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "pc_p1_a_t1",
              "type": "narration",
              "text": "On the screen: a TikTok video. Filmed at the park, last Sunday. Shaky framing, 240p, backlit."
            },
            {
              "id": "pc_p1_a_t2",
              "type": "narration",
              "text": "A figure moves at impossible speed through the trees. Hair that seems to glow. But the shadows are long and the backlight erases every detail."
            },
            {
              "id": "pc_p1_a_t3",
              "type": "narration",
              "text": "Below: 847,000 views. Comments: 'It's a fake', 'I saw her too!', 'Superhero in Nova Tutinia??'"
            },
            {
              "id": "pc_p1_a_t4",
              "type": "narration",
              "text": "Favilla holds her breath. She recognizes herself. But no one else seems to. For now."
            }
          ]
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/s1/s1_prima_conseguenza/page_2.webp",
      "panels": [
        {
          "id": "pc_p2_a",
          "characters": [
            "favilla",
            "mallow",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "pc_p2_a_t1",
              "type": "narration",
              "text": "Mallow is standing, phone still in hand. He looks at her as if searching for something in her face."
            },
            {
              "id": "pc_p2_a_t2",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "It was filmed Sunday. At the park. When you lost your purse."
            },
            {
              "id": "pc_p2_a_t3",
              "type": "narration",
              "text": "Lex, on the rug, has stopped playing. He stares at Favilla. He recognized the video before even looking at it."
            }
          ],
          "choice": {
            "id": "video_choice",
            "prompt": "The video plays. The shadows are indistinguishable. But you know.",
            "options": [
              {
                "id": "minimizza",
                "label": "Shrug. \"Weird. But you know TikTok, everything looks like a ghost.\"",
                "goto_branch": "branch_minimizza",
                "stat_effects": {
                  "segreto": 10,
                  "legame": -5
                },
                "set_flags": {
                  "video_virale_visto": true
                },
                "set_memories": {
                  "choice.s1_prima_conseguenza": "minimizza"
                }
              },
              {
                "id": "devia",
                "label": "\"Anyway, Lex did something amazing today...\"",
                "goto_branch": "branch_devia",
                "stat_effects": {
                  "resistenza": 5,
                  "legame": -3
                },
                "set_flags": {
                  "video_virale_visto": true
                },
                "set_memories": {
                  "choice.s1_prima_conseguenza": "devia"
                }
              },
              {
                "id": "quasi_confessa",
                "label": "\"Maybe... I need to tell you something.\"",
                "goto_branch": "branch_quasi_confessa",
                "stat_effects": {
                  "segreto": -10,
                  "legame": 8
                },
                "set_flags": {
                  "video_virale_visto": true
                },
                "set_memories": {
                  "choice.s1_prima_conseguenza": "quasi_confessa"
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "branches": {
    "intro_gia_visto": {
      "id": "intro_gia_visto",
      "pages": [
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/intro_gia_visto.webp",
          "panels": [
            {
              "id": "intro_gia_visto_a",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "intro_gia_visto_a_t1",
                  "type": "narration",
                  "text": "Favilla opens TikTok. The video is still there. More views. New comments. The same indistinguishable shadow."
                },
                {
                  "id": "intro_gia_visto_a_t2",
                  "type": "narration",
                  "text": "No one has figured it out yet. But every day that passes, someone could."
                },
                {
                  "id": "intro_gia_visto_a_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "I have to be more careful. Much more careful."
                }
              ]
            }
          ],
          "id": "igia_v_p0"
        }
      ]
    },
    "branch_minimizza": {
      "id": "branch_minimizza",
      "pages": [
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/branch_minimizza_0.webp",
          "panels": [
            {
              "id": "branch_minimizza_a",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "branch_minimizza_a_t1",
                  "type": "narration",
                  "text": "Favilla swipes past the video with one finger. Shrugs. Smiles — that smile she's learned to make without thinking."
                },
                {
                  "id": "branch_minimizza_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Weird. But you know TikTok, everything looks like a ghost. Perspective, backlight, editing."
                },
                {
                  "id": "branch_minimizza_a_t3",
                  "type": "narration",
                  "text": "Mallow looks at the video. Then her. Then the video again. Something doesn't add up, but he can't tell what."
                },
                {
                  "id": "branch_minimizza_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Yeah. Probably. Still weird though."
                }
              ]
            }
          ],
          "id": "bminim_p0"
        },
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/branch_minimizza_1.webp",
          "panels": [
            {
              "id": "branch_minimizza_b",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_minimizza_b_t1",
                  "type": "narration",
                  "text": "Mallow goes back to the study. Lex looks at her from the rug with the expression of someone who just watched a mediocre performance."
                },
                {
                  "id": "branch_minimizza_b_t2",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "He didn't recognize me. No one will. I just have to... keep going like this."
                },
                {
                  "id": "branch_minimizza_b_t3",
                  "type": "narration",
                  "text": "The phone goes dark. But the video is still there. And it will be for a long time."
                }
              ]
            }
          ],
          "id": "bminim_p1"
        }
      ]
    },
    "branch_devia": {
      "id": "branch_devia",
      "pages": [
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/branch_devia_0.webp",
          "panels": [
            {
              "id": "branch_devia_a",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_devia_a_t1",
                  "type": "narration",
                  "text": "Favilla changes the subject with the precision of a pilot avoiding an obstacle. Lex. Talk about Lex."
                },
                {
                  "id": "branch_devia_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Anyway, Lex did something incredible today. At daycare. He recognized his name written on the board."
                },
                {
                  "id": "branch_devia_a_t3",
                  "type": "narration",
                  "text": "Mallow lowers the phone. The video disappears from the screen. Lex looks at her like 'nice move, mom'."
                },
                {
                  "id": "branch_devia_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Really? His name? But he's seven months old!"
                }
              ]
            }
          ],
          "id": "bdevia_p0"
        },
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/branch_devia_1.webp",
          "panels": [
            {
              "id": "branch_devia_b",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "branch_devia_b_t1",
                  "type": "narration",
                  "text": "Mallow sits next to her. The conversation derails into how precocious Lex is. The video is forgotten."
                },
                {
                  "id": "branch_devia_b_t2",
                  "type": "narration",
                  "text": "But Favilla has the feeling Mallow hasn't really forgotten. Just postponed."
                },
                {
                  "id": "branch_devia_b_t3",
                  "type": "thought",
                  "speaker": "favilla",
                  "text": "I didn't say anything. But he knows I'm hiding something from him. He's known for weeks."
                }
              ]
            }
          ],
          "id": "bdevia_p1"
        }
      ]
    },
    "branch_quasi_confessa": {
      "id": "branch_quasi_confessa",
      "pages": [
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/branch_quasi_confessa_0.webp",
          "panels": [
            {
              "id": "branch_quasi_confessa_a",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_quasi_confessa_a_t1",
                  "type": "narration",
                  "text": "Favilla hesitates. The phone is warm in her hand. The video plays. Then stops playing."
                },
                {
                  "id": "branch_quasi_confessa_a_t2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "That day... I was there. At the park. I saw everything."
                },
                {
                  "id": "branch_quasi_confessa_a_t3",
                  "type": "narration",
                  "text": "Mallow stops the spoon mid-air. The seconds stretch. Lex, on the rug, is motionless as a statue."
                },
                {
                  "id": "branch_quasi_confessa_a_t4",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "What did you see?"
                }
              ]
            }
          ],
          "id": "bquasi_p0"
        },
        {
          "background": "assets/episodes/s1/s1_prima_conseguenza/branch_quasi_confessa_1.webp",
          "panels": [
            {
              "id": "branch_quasi_confessa_b",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "branch_quasi_confessa_b_t1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "The thief. I saw him. He ran toward the grove. I was there when it happened."
                },
                {
                  "id": "branch_quasi_confessa_b_t2",
                  "type": "narration",
                  "text": "Half-truth. The part Mallow can accept. The other half — the speed, the hair, the light — stays buried."
                },
                {
                  "id": "branch_quasi_confessa_b_t3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Why didn't you tell me?"
                },
                {
                  "id": "branch_quasi_confessa_b_t4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Because... I don't know. Maybe I was afraid you'd worry."
                },
                {
                  "id": "branch_quasi_confessa_b_t5",
                  "type": "narration",
                  "text": "Lex smiles. He got what he wanted. Not the whole truth. But a step."
                }
              ]
            }
          ],
          "id": "bquasi_p1"
        }
      ]
    }
  },
  "epilogue": {
    "id": "epilogue",
    "pages": [
      {
        "background": "assets/episodes/s1/s1_prima_conseguenza/epilogue.webp",
        "panels": [
          {
            "id": "pc_epilogue_a",
            "characters": [
              "favilla"
            ],
            "text_blocks": [
              {
                "id": "pc_epilogue_a_t1",
                "type": "narration",
                "text": "Favilla is in the bedroom. The phone is on the nightstand, screen off. But the video is still there, in her mind."
              },
              {
                "id": "pc_epilogue_a_t2",
                "type": "narration",
                "text": "A comment under the video: 'Looks like a superhero.' Another: 'Superhero my ass, it's Photoshop.' A third: 'I live in Nova Tutinia and let me tell you, nothing is normal here.'"
              },
              {
                "id": "pc_epilogue_a_t3",
                "type": "narration",
                "text": "No one knows. No one can know. But the world has started watching."
              },
              {
                "id": "pc_epilogue_a_t4",
                "type": "system",
                "text": "MISSION COMPLETE — The First Consequence"
              }
            ]
          }
        ],
        "id": "ep_p0"
      }
    ]
  }
}