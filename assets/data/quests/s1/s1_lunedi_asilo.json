{
  "id": "s1_lunedi_asilo",
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/s1/s1_lunedi_asilo/page_0.webp",
      "panels": [
        {
          "id": "sla0_0",
          "characters": [
            "favilla",
            "mallow",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "sla0_0_tb_0",
              "type": "narration",
              "text": "Lunedì mattina. Casa. Il sole è appena entrato dalla finestra del corridoio."
            },
            {
              "id": "sla0_0_tb_1",
              "type": "narration",
              "text": "Favilla è in ginocchio sul pavimento del soggiorno con lo zaino di Lex aperto davanti. Gufetto dentro. Cambio dentro. Merenda dentro. Fastidio dentro."
            },
            {
              "id": "sla0_0_tb_2",
              "type": "thought",
              "text": "Chi ha deciso che a sette mesi si può già avere un zaino?",
              "speaker": "favilla"
            },
            {
              "id": "sla0_0_tb_3",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "«Ci metti anche il manuale di istruzioni per i maestre?»"
            },
            {
              "id": "sla0_0_tb_4",
              "type": "thought",
              "text": "Non è divertente. Un po' lo è.",
              "speaker": "favilla"
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_lunedi_asilo/page_1.webp",
      "panels": [
        {
          "id": "sla1_0",
          "characters": [
            "mallow",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "sla1_0_tb_0",
              "type": "narration",
              "text": "Lex è nel box. Mallow gli ha sistemato accanto il notebook — «un secondo, poi torno» — ed è andato in cucina."
            },
            {
              "id": "sla1_0_tb_1",
              "type": "narration",
              "text": "Il notebook è aperto. Schermata di login. Password oscurata da asterischi."
            },
            {
              "id": "sla1_0_tb_2",
              "type": "narration",
              "text": "Lex lo fissa. Lo fissa davvero."
            },
            {
              "id": "sla1_0_tb_3",
              "type": "thought",
              "text": "Lex sa già il segreto. Gli serve solo entrare nel notebook per costruire il dispositivo e smascherarla.",
              "speaker": "favilla"
            },
            {
              "id": "sla1_0_tb_4",
              "type": "narration",
              "text": "Allunga una mano. Poi l'altra. Raggiunge la tastiera."
            }
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "crack_password_choice",
        "prompt": "Lex scruta lo schermo. Un clic. Un altro. Un piano.",
        "options": [
          {
            "id": "mentire",
            "label": "«Lex, no!» Prende il notebook. Innervosita vera.",
            "goto_branch": "branch_scoperta_quasi",
            "stat_effects": {
              "segreto": 10,
              "resistenza": -3,
              "legame": -2
            },
            "setMemories": {
              "choice_intent.s1_lunedi_asilo.crack_password_choice": "panicked"
            }
          },
          {
            "id": "tenta_password",
            "label": "Tenta.",
            "goto_branch": "branch_genio",
            "stat_effects": {},
            "minigame": {
              "type": "crack_password",
              "tiers": [
                {
                  "min": 2,
                  "label": "Genio.",
                  "goto_branch": "branch_genio",
                  "stat_effects": {
                    "segreto": -5
                  },
                  "set_flags": {
                    "lex_ha_un_piano": true
                  }
                },
                {
                  "min": 1,
                  "label": "Quasi.",
                  "goto_branch": "branch_quasi",
                  "stat_effects": {
                    "legame": 5
                  }
                },
                {
                  "min": 0,
                  "label": "Beccato.",
                  "goto_branch": "branch_beccato",
                  "stat_effects": {
                    "legame": 10
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "branches": {
    "branch_scoperta_quasi": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_lunedi_asilo/page_scoperta.webp",
          "panels": [
            {
              "id": "sla_scoperta_0",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "sla_scoperta_0_tb_0",
                  "type": "narration",
                  "text": "Favilla vede il notebook aperto. Lex con le mani sulla tastiera. Reagisce secco."
                },
                {
                  "id": "sla_scoperta_0_tb_1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "«Via di lì.»"
                },
                {
                  "id": "sla_scoperta_0_tb_2",
                  "type": "narration",
                  "text": "Non è una domanda. È stanchezza che diventa comando. La mano le trema un po' — non di paura. Di tensione cumulata."
                },
                {
                  "id": "sla_scoperta_0_tb_3",
                  "type": "narration",
                  "text": "Lex guarda il notebook. Poi guarda mamma. Mamma ha paura del notebook. Non dell'acqua. Non di cadute. Di quello che c'è dentro."
                },
                {
                  "id": "sla_scoperta_0_tb_4",
                  "type": "thought",
                  "text": "È lì. I dati. Lo schema. Tutto quello che serviva per costruire il rilevatore. Lei lo sa che potrebbe servire.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ],
          "id": "bscope_p0"
        }
      ]
    },
    "branch_genio": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_lunedi_asilo/page_genio.webp",
          "panels": [
            {
              "id": "sla_bg_0",
              "characters": [
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "sla_bg_0_tb_0",
                  "type": "narration",
                  "text": "Il notebook si sblocca. Lex spalanca gli occhi."
                },
                {
                  "id": "sla_bg_0_tb_1",
                  "type": "narration",
                  "text": "Apre una cartella. Un'altra. Trova un programma con tante forme colorate. Comincia a disegnare: cerchi, frecce, simboli."
                },
                {
                  "id": "sla_bg_0_tb_2",
                  "type": "thought",
                  "text": "Rilevatore di energia. Sì. Come fa la mamma a scaldarsi — ci deve essere uno schema.",
                  "speaker": "favilla"
                },
                {
                  "id": "sla_bg_0_tb_3",
                  "type": "narration",
                  "text": "Passi in corridoio. Lex chiude il notebook in due secondi. Torna nella posizione di default: sdraiato, gufetto in mano, aria da dormire."
                },
                {
                  "id": "sla_bg_0_tb_4",
                  "type": "narration",
                  "text": "Mallow non ha notato niente. Favilla neanche. Lex ha un piano."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bgenio_p0"
        }
      ]
    },
    "branch_quasi": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_lunedi_asilo/page_quasi.webp",
          "panels": [
            {
              "id": "sla_bq_0",
              "characters": [
                "lex",
                "mallow",
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "sla_bq_0_tb_0",
                  "type": "narration",
                  "text": "Quasi. La password era lì, a un simbolo di distanza."
                },
                {
                  "id": "sla_bq_0_tb_1",
                  "type": "narration",
                  "text": "Passi in corridoio. Mallow e Favilla tornano dalla cucina."
                },
                {
                  "id": "sla_bq_0_tb_2",
                  "type": "narration",
                  "text": "Trovano Lex con le mani sulla tastiera, lo sguardo concentrato come un piccolo ingegnere."
                },
                {
                  "id": "sla_bq_0_tb_3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "«Ma… sta cercando di—?»"
                },
                {
                  "id": "sla_bq_0_tb_4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "«Non dire una parola.»"
                },
                {
                  "id": "sla_bq_0_tb_5",
                  "type": "narration",
                  "text": "Ridono. In silenzio, ma ridono."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bquasi_p0"
        }
      ]
    },
    "branch_beccato": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_lunedi_asilo/page_beccato.webp",
          "panels": [
            {
              "id": "sla_bb_0",
              "characters": [
                "lex",
                "mallow",
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "sla_bb_0_tb_0",
                  "type": "narration",
                  "text": "La password resiste. Lex non cede: continua a premere tasti con aria metodica."
                },
                {
                  "id": "sla_bb_0_tb_1",
                  "type": "narration",
                  "text": "Mallow e Favilla tornano dalla cucina. Si fermano sulla soglia."
                },
                {
                  "id": "sla_bb_0_tb_2",
                  "type": "narration",
                  "text": "Lex: manine sulla tastiera, espressione mortalmente seria, schiena dritta."
                },
                {
                  "id": "sla_bb_0_tb_3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "«...Sta hackerando il mio notebook.»"
                },
                {
                  "id": "sla_bb_0_tb_4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "«Ovviamente.»"
                },
                {
                  "id": "sla_bb_0_tb_5",
                  "type": "narration",
                  "text": "Ridono fino a che Lex li guarda con l'aria offesa di chi stava lavorando."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bbecca_p0"
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "background": "assets/episodes/s1/s1_lunedi_asilo/page_epilogo_0.webp",
        "panels": [
          {
            "id": "ep_sla_0",
            "characters": [
              "favilla",
              "mallow",
              "lex"
            ],
            "text_blocks": [
              {
                "id": "ep_sla_0_tb_0",
                "type": "narration",
                "text": "Dieci minuti dopo. La famiglia esce di casa."
              },
              {
                "id": "ep_sla_0_tb_1",
                "type": "narration",
                "text": "Mallow ha la chiave. Favilla ha lo zaino. Lex ha il gufetto e un'espressione che non promette niente di buono."
              },
              {
                "id": "ep_sla_0_tb_2",
                "type": "thought",
                "text": "Asilo. Bene. Nuovo territorio. Dopo {{memory:choice_label.s1_centro_commerciale.carmela_dialogo_choice|la scena con Carmela}}, nuove variabili da mappare.",
                "speaker": "favilla"
              }
            ],
            "interactions": []
          }
        ],
        "id": "ep_p0"
      },
      {
        "background": "assets/episodes/s1/s1_lunedi_asilo/page_epilogo_1.webp",
        "panels": [
          {
            "id": "ep_sla_1",
            "characters": [],
            "text_blocks": [
              {
                "id": "ep_sla_1_tb_0",
                "type": "narration",
                "text": "Asilo Comunale di Nova Tutinia."
              },
              {
                "id": "ep_sla_1_tb_1",
                "type": "narration",
                "text": "Giochi colorati nel cortile. Una maestra che sorride con la stanchezza professionale di chi ne ha viste tante."
              },
              {
                "id": "ep_sla_1_tb_2",
                "type": "narration",
                "text": "Un nuovo posto sulla mappa."
              }
            ],
            "interactions": []
          }
        ],
        "id": "ep_p1"
      }
    ]
  }
}