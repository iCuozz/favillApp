                "lex"
              ],
              "text_blocks": [
                {
                  "id": "sp_esausta_0_tb_0",
                  "type": "narration",
                  "text": "Favilla spinge il carrello come se pesasse il doppio del solito."
                },
                {
                  "id": "sp_esausta_0_tb_1",
                  "type": "narration",
                  "text": "Le gambe sono di piombo. Ogni passo è una trattativa con il corpo: uno ancora, poi uno ancora."
                },
                {
                  "id": "sp_esausta_0_tb_2",
                  "type": "narration",
                  "text": "Lex la guarda dal seggiolino. Non dice niente — ma Lex non dice mai niente quando la mamma è così. La osserva, come se aspettasse che lei si fermi."
                },
                {
                  "id": "sp_esausta_0_tb_3",
                  "type": "thought",
                  "text": "Ancora un corridoio. Poi la cassa. Poi casa. Ce la posso fare.",
                  "speaker": "favilla"
                }
              ]
            }
          ],
          "id": "iesaus_p0"
        }
      ]
    }
