  ],
  "branches": {
    "intro_mallow_sa_qualcosa": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_intro_mallow.webp",
          "panels": [
            {
              "id": "scc_imq_0",
              "characters": ["favilla", "mallow"],
              "text_blocks": [
                {"id": "scc_imq_0_tb_0", "type": "narration", "text": "In the car, Mallow drives with one hand on the wheel. The other is on the gearshift — not holding her hand, but it's there."},
                {"id": "scc_imq_0_tb_1", "type": "dialogue", "speaker": "mallow", "text": "\"You don't have to tell me anything. You know that, right? You don't have to tell me anything.\""},
                {"id": "scc_imq_0_tb_2", "type": "narration", "text": "Favilla watches Nova Tutinia's profile slip past the window."},
                {"id": "scc_imq_0_tb_3", "type": "thought", "text": "He knows. Doesn't know what. But he knows there's something. And he's chosen to wait."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "intro_mani_calde": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_intro_mani.webp",
          "panels": [
            {
              "id": "scc_imc_0",
              "characters": ["favilla"],
              "text_blocks": [
                {"id": "scc_imc_0_tb_0", "type": "narration", "text": "In the car, Favilla keeps her hands in her lap. Palms down — so nobody can see."},
                {"id": "scc_imc_0_tb_1", "type": "narration", "text": "They're not burning. Not yet. But there's that feeling — like coal just gone out under the ash."},
                {"id": "scc_imc_0_tb_2", "type": "thought", "text": "Crowd. Lights. Air conditioning. At least here nothing shows."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_preso_subito": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_corridoio.webp",
          "panels": [
            {
              "id": "scc_ps_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                {"id": "scc_ps_0_tb_0", "type": "narration", "text": "Caught in three steps. Lex makes the sound of someone who lost a negotiation."},
                {"id": "scc_ps_0_tb_1", "type": "dialogue", "speaker": "mallow", "text": "\"Nice chase.\""},
                {"id": "scc_ps_0_tb_2", "type": "narration", "text": "Favilla holds him tight. Breathes. Okay. Nobody saw anything particular."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_quasi_casino": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_corridoio.webp",
          "panels": [
            {
              "id": "scc_qc_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                {"id": "scc_qc_0_tb_0", "type": "narration", "text": "Lex nearly takes out the decorative glass stand. Favilla grabs him by a centimetre."},
                {"id": "scc_qc_0_tb_1", "type": "narration", "text": "A couple near the fountain turned around. They look at Lex. They look at Favilla. They look again."},
                {"id": "scc_qc_0_tb_2", "type": "thought", "text": "They didn't see anything. It was just a chase. Normal. Completely normal."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_momento_tenero": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_fontana.webp",
          "panels": [
            {
              "id": "scc_mt_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                {"id": "scc_mt_0_tb_0", "type": "narration", "text": "Favilla catches him near the ground-floor fountain. Coins at the bottom, the water gurgling."},
                {"id": "scc_mt_0_tb_1", "type": "narration", "text": "Lex turns toward her. Clear eyes. He lifts a hand and places it on Favilla's cheek — with a gentleness he hasn't yet learned to do on purpose."},
                {"id": "scc_mt_0_tb_2", "type": "thought", "text": "Seven months old. No words yet. But he knows exactly where I need to be touched to stop running."},
                {"id": "scc_mt_0_tb_3", "type": "narration", "text": "Someone nearby has seen. Favilla feels eyes on her — and doesn't care. Then she does."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "index": 0,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_supermercato.webp",
        "panels": [
          {
            "id": "ep_scc_0",
            "characters": ["favilla", "mallow", "lex"],
            "text_blocks": [
              {"id": "ep_scc_0_tb_0", "type": "narration", "text": "Lex is back in the stroller. He's clutching the plastic giraffe — they bought it. It was inevitable."},
              {"id": "ep_scc_0_tb_1", "type": "narration", "text": "Mallow pushes the cart toward the internal supermarket checkout. Favilla walks beside him."}
            ],
            "interactions": []
          }
        ]
      },
      {
        "index": 1,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_cassa.webp",
        "panels": [
          {
            "id": "ep_scc_1",
            "characters": ["favilla", "carmela"],
            "text_blocks": [
              {"id": "ep_scc_1_tb_0", "type": "narration", "text": "In line at the checkout: Carmela. Blue trolley. Straw hat. Eyes that miss nothing."},
              {"id": "ep_scc_1_tb_1", "type": "dialogue", "speaker": "carmela", "text": "\"Favilla dear! What a nice surprise. I was watching you from across the corridor — you have a light in your hair I'd never noticed before. Are you all right?\""},
              {"id": "ep_scc_1_tb_2", "type": "narration", "text": "She smiles. It's not a question. It's a sowing."}
            ],
            "interactions": []
          }
        ],
        "choice": {
          "id": "carmela_risposta",
          "prompt": "Carmela is waiting. She has all the time in the world.",
          "options": [
            {
              "id": "risposta_bene",
              "label": "\"I'm great, thanks Carmela.\"",
              "goto_branch": "",
              "stat_effects": {"segreto": -2}
            },
            {
              "id": "risposta_sole",
              "label": "\"It's the sun lately.\"",
              "goto_branch": "",
              "stat_effects": {"segreto": -8}
            },
            {
              "id": "risposta_lex",
              "label": "She picks up Lex. Without answering.",
              "goto_branch": "",
              "stat_effects": {"legame": 5, "segreto": -3}
            }
          ]
        }
      },
      {
        "index": 2,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_parcheggio.webp",
        "panels": [
          {
            "id": "ep_scc_2",
            "characters": ["favilla", "mallow"],
            "text_blocks": [
              {"id": "ep_scc_2_tb_0", "type": "narration", "text": "Car park. The sun beats on the concrete."},
              {"id": "ep_scc_2_tb_1", "type": "narration", "text": "Mallow carries the bags. Lex sleeps in the stroller, giraffe clutched in his fist."},
              {"id": "ep_scc_2_tb_2", "type": "dialogue", "speaker": "mallow", "text": "\"Not every day needs to be something. Some days can just be nice.\""},
              {"id": "ep_scc_2_tb_3", "type": "thought", "text": "It was normal. It was actually normal."}
            ],
            "interactions": []
          }
        ]
      },
      {
        "index": 3,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_gatto_parcheggio.webp",
        "panels": [
          {
            "id": "ep_scc_3",
            "characters": ["gatto"],
            "text_blocks": [
              {"id": "ep_scc_3_tb_0", "type": "narration", "text": "On the bonnet of the next car: the cat."},
              {"id": "ep_scc_3_tb_1", "type": "narration", "text": "Yellow eyes. Orange fur. Tail curled with the air of someone who knows exactly where they need to be."},
              {"id": "ep_scc_3_tb_2", "type": "narration", "text": "It stands. Steps down. Heading for number 19, third floor."}
            ],
            "interactions": []
          }
        ],
        "choice": {
          "id": "fine_mall",
          "prompt": "Some days can just be nice.",
          "options": [
            {
              "id": "torna_casa",
              "label": "Some days can just be nice.",
