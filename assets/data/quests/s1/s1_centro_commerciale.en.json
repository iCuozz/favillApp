      "panels": [
        {
          "id": "scc0_0",
          "characters": ["favilla", "mallow", "lex"],
          "text_blocks": [
            {"id": "scc0_0_tb_0", "type": "narration", "text": "GalaxiaMall. Ground floor. Saturday morning."},
            {"id": "scc0_0_tb_1", "type": "narration", "text": "Lex in the stroller, eyes wide open on the LED ceiling lights. Waves one hand like he's greeting the future."},
            {"id": "scc0_0_tb_2", "type": "narration", "text": "Mallow navigates the Saturday crowd with the precision of someone who has done orienteering."},
            {"id": "scc0_0_tb_3", "type": "thought", "text": "Nobody knows me here. Here I can just buy soap and that's it."}
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_centro_commerciale/page_1.webp",
      "panels": [
        {
          "id": "scc1_0",
          "characters": ["favilla", "mallow", "lex"],
          "text_blocks": [
            {"id": "scc1_0_tb_0", "type": "narration", "text": "Kids & Fantasy. Ground floor, west wing."},
            {"id": "scc1_0_tb_1", "type": "narration", "text": "Lex spots a plastic giraffe on the display stand — squeaky neck, absurd ears. He stares at it like someone making an important decision."},
            {"id": "scc1_0_tb_2", "type": "dialogue", "speaker": "mallow", "text": "\"Ah. He's decided.\""},
            {"id": "scc1_0_tb_3", "type": "narration", "text": "In one non-negotiable moment — Lex slips out of the stroller toward the main corridor."}
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/s1/s1_centro_commerciale/page_2.webp",
      "panels": [
        {
          "id": "scc2_0",
          "characters": ["favilla", "lex"],
          "text_blocks": [
            {"id": "scc2_0_tb_0", "type": "narration", "text": "Seven months old. Four teeth. Inexplicable determination."},
            {"id": "scc2_0_tb_1", "type": "thought", "text": "No. No no no no."}
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "rincorsa_mall_choice",
        "prompt": "Lex heads for the GalaxiaMall main corridor.",
        "options": [
          {
            "id": "rincorri_lex_mall",
            "label": "Chase him.",
            "goto_branch": "branch_preso_subito",
            "stat_effects": {},
            "minigame": {
              "type": "rincorsa_lex",
