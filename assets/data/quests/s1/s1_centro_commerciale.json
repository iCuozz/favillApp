  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/s1/s1_centro_commerciale/page_0.webp",
      "panels": [
        {
          "id": "scc0_0",
          "characters": ["favilla", "mallow", "lex"],
          "text_blocks": [
            {"id": "scc0_0_tb_0", "type": "narration", "text": "GalaxiaMall. Piano terra. Sabato mattina."},
            {"id": "scc0_0_tb_1", "type": "narration", "text": "Lex sul passeggino tiene gli occhi aperti sulle luci LED del soffitto. Agita una mano come se stesse salutando il futuro."},
            {"id": "scc0_0_tb_2", "type": "narration", "text": "Mallow naviga la folla sabatina con la precisione di chi ha fatto orienteering."},
            {"id": "scc0_0_tb_3", "type": "thought", "text": "In questo posto non mi conosce nessuno. In questo posto posso solo comprare il sapone e basta."}
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_centro_commerciale/page_1.webp",
      "panels": [
        {
          "id": "scc1_0",
          "characters": ["favilla", "mallow", "lex"],
          "text_blocks": [
            {"id": "scc1_0_tb_0", "type": "narration", "text": "Bimbi & Fantasia. Piano terra, ala ovest."},
            {"id": "scc1_0_tb_1", "type": "narration", "text": "Lex individua una giraffa di plastica sul banchetto display — collo cigolante, orecchie assurde. La fissa come chi sta prendendo una decisione importante."},
            {"id": "scc1_0_tb_2", "type": "dialogue", "speaker": "mallow", "text": "«Ah. Ha deciso.»"},
            {"id": "scc1_0_tb_3", "type": "narration", "text": "In un momento non negoziabile — Lex scivola via dal passeggino verso il corridoio principale."}
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/s1/s1_centro_commerciale/page_2.webp",
      "panels": [
        {
          "id": "scc2_0",
          "characters": ["favilla", "lex"],
          "text_blocks": [
            {"id": "scc2_0_tb_0", "type": "narration", "text": "Sette mesi. Quattro denti. Una determinazione inesplicabile."},
            {"id": "scc2_0_tb_1", "type": "thought", "text": "No. No no no no."}
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "rincorsa_mall_choice",
        "prompt": "Lex punta verso il corridoio centrale del GalaxiaMall.",
        "options": [
          {
            "id": "rincorri_lex_mall",
            "label": "Rincorrilo.",
            "goto_branch": "branch_preso_subito",
            "stat_effects": {},
            "minigame": {
              "type": "rincorsa_lex",
              "theme": "mall",
              "duration_seconds": 15,
              "tiers": [
                {
                  "min": 5,
                  "label": "Preso!",
                  "goto_branch": "branch_preso_subito",
                  "stat_effects": {"resistenza": 10, "legame": 5}
                },
                {
                  "min": 2,
                  "label": "Quasi!",
                  "goto_branch": "branch_quasi_casino",
                  "stat_effects": {"resistenza": 5, "segreto": -5}
                },
                {
                  "min": 0,
                  "label": "...",
                  "goto_branch": "branch_momento_tenero",
                  "stat_effects": {"legame": 15, "scintille": 5, "segreto": -5}
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "branches": {
    "intro_mallow_sa_qualcosa": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_intro_mallow.webp",
          "panels": [
            {
              "id": "scc_imq_0",
              "characters": ["favilla", "mallow"],
              "text_blocks": [
                {"id": "scc_imq_0_tb_0", "type": "narration", "text": "In macchina, Mallow guida tenendo il volante con una mano sola. L'altra è sul cambio — non la prende, ma è lì."},
                {"id": "scc_imq_0_tb_1", "type": "dialogue", "speaker": "mallow", "text": "«Non devi dirmi niente. Lo sai, vero? Non devi dirmi niente.»"},
                {"id": "scc_imq_0_tb_2", "type": "narration", "text": "Favilla guarda il profilo di Nova Tutinia scorrere oltre il finestrino."},
                {"id": "scc_imq_0_tb_3", "type": "thought", "text": "Lo sa. Non sa cosa. Ma sa che c'è qualcosa. E ha scelto di aspettare."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "intro_mani_calde": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_intro_mani.webp",
          "panels": [
            {
              "id": "scc_imc_0",
              "characters": ["favilla"],
              "text_blocks": [
                {"id": "scc_imc_0_tb_0", "type": "narration", "text": "In macchina, Favilla tiene le mani in grembo. I palmi verso il basso — così non si vede."},
                {"id": "scc_imc_0_tb_1", "type": "narration", "text": "Non bruciano. Non ancora. Ma c'è quella sensazione — come carbone appena spento sotto la cenere."},
                {"id": "scc_imc_0_tb_2", "type": "thought", "text": "Folla. Luci. Aria condizionata. Almeno qui non si vede niente."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_preso_subito": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_corridoio.webp",
          "panels": [
            {
              "id": "scc_ps_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                {"id": "scc_ps_0_tb_0", "type": "narration", "text": "Preso in tre passi. Lex emette il verso di chi ha perso una trattativa."},
                {"id": "scc_ps_0_tb_1", "type": "dialogue", "speaker": "mallow", "text": "«Bella rincorsa.»"},
                {"id": "scc_ps_0_tb_2", "type": "narration", "text": "Favilla lo tiene stretto. Respira. Okay. Nessuno ha visto niente di particolare."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_quasi_casino": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_corridoio.webp",
          "panels": [
            {
              "id": "scc_qc_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                {"id": "scc_qc_0_tb_0", "type": "narration", "text": "Lex quasi centra il banchetto dei bicchieri di vetro decorativi. Favilla lo afferra per un centimetro."},
                {"id": "scc_qc_0_tb_1", "type": "narration", "text": "Una coppia vicino alla fontana si è girata. Guarda Lex. Guarda Favilla. Guarda ancora."},
                {"id": "scc_qc_0_tb_2", "type": "thought", "text": "Non hanno visto niente. Era solo una rincorsa. Normale. Normalissima."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_momento_tenero": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/s1/s1_centro_commerciale/page_fontana.webp",
          "panels": [
            {
              "id": "scc_mt_0",
              "characters": ["favilla", "lex"],
              "text_blocks": [
                {"id": "scc_mt_0_tb_0", "type": "narration", "text": "Favilla lo prende vicino alla fontana del piano terra. Le monetine sul fondo, l'acqua che gorgoglia."},
                {"id": "scc_mt_0_tb_1", "type": "narration", "text": "Lex si gira verso di lei. Gli occhi chiari. Alza una mano e la mette sulla guancia di Favilla — con una gentilezza che non ha ancora imparato a fare apposta."},
                {"id": "scc_mt_0_tb_2", "type": "thought", "text": "Sette mesi. Non sa ancora le parole. Ma sa esattamente dove devo essere toccata per smettere di correre."},
                {"id": "scc_mt_0_tb_3", "type": "narration", "text": "Qualcuno intorno ha visto. Favilla sente gli occhi addosso — e non le importa. Poi le importa."}
              ],
              "interactions": []
            }
          ]
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "index": 0,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_supermercato.webp",
        "panels": [
          {
            "id": "ep_scc_0",
            "characters": ["favilla", "mallow", "lex"],
            "text_blocks": [
              {"id": "ep_scc_0_tb_0", "type": "narration", "text": "Lex è di nuovo sul passeggino. Tiene la giraffa di plastica stretta nel pugno — l'hanno comprata. Era inevitabile."},
              {"id": "ep_scc_0_tb_1", "type": "narration", "text": "Mallow spinge il carrello verso la cassa del supermercato interno. Favilla cammina accanto."}
            ],
            "interactions": []
          }
        ]
      },
      {
        "index": 1,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_cassa.webp",
        "panels": [
          {
            "id": "ep_scc_1",
            "characters": ["favilla", "carmela"],
            "text_blocks": [
              {"id": "ep_scc_1_tb_0", "type": "narration", "text": "In fila alla cassa: Carmela. Trolley blu. Cappello di paglia. Gli occhi che non perdono niente."},
              {"id": "ep_scc_1_tb_1", "type": "dialogue", "speaker": "carmela", "text": "«Favilla cara! Che bella sorpresa. Ti osservavo dall'altra parte del corridoio — hai una luce nei capelli che non avevo mai notato. Stai bene?»"},
              {"id": "ep_scc_1_tb_2", "type": "narration", "text": "Sorride. Non è una domanda. È una semina."}
            ],
            "interactions": []
          }
        ],
        "choice": {
          "id": "carmela_risposta",
          "prompt": "Carmela aspetta. Ha tutto il tempo del mondo.",
          "options": [
            {
              "id": "risposta_bene",
              "label": "«Sto benissimo, grazie Carmela.»",
              "goto_branch": "",
              "stat_effects": {"segreto": -2}
            },
            {
              "id": "risposta_sole",
              "label": "«È il sole di questi giorni.»",
              "goto_branch": "",
              "stat_effects": {"segreto": -8}
            },
            {
              "id": "risposta_lex",
              "label": "Prende Lex in braccio. Senza rispondere.",
              "goto_branch": "",
              "stat_effects": {"legame": 5, "segreto": -3}
            }
          ]
        }
      },
      {
        "index": 2,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_parcheggio.webp",
        "panels": [
          {
            "id": "ep_scc_2",
            "characters": ["favilla", "mallow"],
            "text_blocks": [
              {"id": "ep_scc_2_tb_0", "type": "narration", "text": "Parcheggio. Il sole batte sul cemento."},
              {"id": "ep_scc_2_tb_1", "type": "narration", "text": "Mallow porta i sacchetti. Lex dorme sul passeggino, la giraffa stretta nel pugno."},
              {"id": "ep_scc_2_tb_2", "type": "dialogue", "speaker": "mallow", "text": "«Non tutte le giornate devono essere qualcosa. Alcune possono solo essere belle.»"},
              {"id": "ep_scc_2_tb_3", "type": "thought", "text": "È stata normale. È stata proprio normale."}
            ],
            "interactions": []
          }
        ]
      },
      {
        "index": 3,
        "background": "assets/episodes/s1/s1_centro_commerciale/page_gatto_parcheggio.webp",
        "panels": [
          {
            "id": "ep_scc_3",
            "characters": ["gatto"],
            "text_blocks": [
              {"id": "ep_scc_3_tb_0", "type": "narration", "text": "Sul cofano della macchina accanto: il gatto."},
              {"id": "ep_scc_3_tb_1", "type": "narration", "text": "Gli occhi gialli. Il pelo arancione. La coda arrotolata con l'aria di chi sa esattamente dove deve essere."},
              {"id": "ep_scc_3_tb_2", "type": "narration", "text": "Si alza. Scende. Direzione civico 19, terzo piano."}
            ],
            "interactions": []
          }
        ],
        "choice": {
          "id": "fine_mall",
          "prompt": "Alcune giornate possono solo essere belle.",
          "options": [
            {
              "id": "torna_casa",
              "label": "Alcune giornate possono solo essere belle.",
              "goto_branch": "",
              "stat_effects": {"resistenza": 15}
            }
          ]
        }
      }
    ]
  }
}
