{
  "id": "s1_crepa",
  "audio_theme": "ritorno_casa_hum",
  "stat_entry": [
    {
      "stat": "segreto",
      "op": "lte",
      "value": 10,
      "goto_branch": "intro_precaria",
      "prepend": true
    }
  ],
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/prologo/page_3.png",
      "panels": [
        {
          "id": "cr_p0_a",
          "characters": [
            "favilla",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "cr_p0_a_t1",
              "type": "narration",
              "text": "Notte fonda. La cucina è spenta. Solo la luce del frigo quando Mallow apre lo sportello e si ferma."
            },
            {
              "id": "cr_p0_a_t2",
              "type": "narration",
              "text": "Ha in mano qualcosa. Un pezzo di stoffa. La camicia bruciata — quella che Favilla aveva nascosto in fondo allo zaino e detto di aver buttato."
            },
            {
              "id": "cr_p0_a_t3",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "L'ho trovata stamattina. Mentre cercavo il caricatore di Lex."
            },
            {
              "id": "cr_p0_a_t4",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Non volevo frugare. Ma ormai l'avevo in mano. E non sapevo cosa farmene."
            },
            {
              "id": "cr_p0_a_t5",
              "type": "narration",
              "text": "Non è arrabbiato. È peggio. È ferito."
            }
          ]
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/prologo/page_4.png",
      "panels": [
        {
          "id": "cr_p1_a",
          "characters": [
            "favilla",
            "mallow",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "cr_p1_a_t1",
              "type": "narration",
              "text": "Favilla sente le mani scaldarsi. Le nasconde dietro la schiena. Il gesto non sfugge a Mallow."
            },
            {
              "id": "cr_p1_a_t2",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Non voglio litigare. Voglio solo... capire. Ma se non vuoi dirmi niente, almeno dimmi perché non puoi dirmelo."
            },
            {
              "id": "cr_p1_a_t3",
              "type": "narration",
              "text": "Dal box, un fruscio. Lex è sveglio."
            },
            {
              "id": "cr_p1_a_t4",
              "type": "narration",
              "text": "Non piange. Non ride. Guarda. E per la prima volta, Favilla vede qualcosa nei suoi occhi che non aveva mai visto: tristezza."
            },
            {
              "id": "cr_p1_a_t5",
              "type": "narration",
              "text": "Lex ha voluto tutto questo. Il suo piano era far scoprire la verità al papà. Ma ora che vede mamma e papà così — uno di fronte all'altra, distanti — non è più sicuro di volerlo."
            },
            {
              "id": "cr_p1_a_t6",
              "type": "thought",
              "speaker": "favilla",
              "text": "Lex. Anche tu. Anche tu sai. E anche tu stai soffrendo."
            }
          ]
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/prologo/page_3.png",
      "panels": [
        {
          "id": "cr_p2_a",
          "characters": [
            "favilla",
            "mallow",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "cr_p2_a_t1",
              "type": "narration",
              "text": "L'aria è ferma. Mallow aspetta. Lex trattiene il respiro. Le mani di Favilla scottano."
            },
            {
              "id": "cr_p2_a_t2",
              "type": "thought",
              "speaker": "favilla",
              "text": "Posso girarmi. Posso mentire. Posso dirgli quasi tutto."
            },
            {
              "id": "cr_p2_a_t3",
              "type": "narration",
              "text": "Ma niente sarà più come prima. Qualunque cosa scelga."
            }
          ],
          "choice": {
            "id": "crepa_choice",
            "prompt": "La camicia bruciata è sul tavolo. Mallow aspetta. Lex guarda.",
            "options": [
              {
