    "branch_preso_bene": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mare/page_lex_preso.webp",
          "panels": [
            {
              "id": "bpb_0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bpb_0_tb_0",
                  "type": "narration",
                  "text": "Afferrato in tempo. Lex emette un verso di protesta solenne — poi trova una conchiglia e se ne dimentica di tutto il resto."
                },
                {
                  "id": "bpb_0_tb_1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "«Un fulmine, eh.»"
                },
                {
                  "id": "bpb_0_tb_2",
                  "type": "narration",
                  "text": "Lex non risponde. Sta già analizzando la conchiglia con la stessa intensità con cui, un attimo prima, stava analizzando il mare."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bpreso_p0"
        }
      ]
    },
    "branch_quasi_visto": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mare/page_lex_preso.webp",
          "panels": [
            {
              "id": "bqv_0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bqv_0_tb_0",
                  "type": "narration",
                  "text": "Preso — ma la signora con il cappello di paglia ha visto qualcosa. O pensa di aver visto."
                },
                {
                  "id": "bqv_0_tb_1",
                  "type": "narration",
                  "text": "Favilla sorride — quel sorriso generico da spiaggia che dice 'bambini, eh' — e la signora annuisce, non del tutto convinta."
                },
                {
                  "id": "bqv_0_tb_2",
                  "type": "narration",
                  "text": "Lex fa l'occhiolino alla signora. La signora non sa cosa ha visto. Lex sì."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bquasi_p0"
        }
      ]
    },
    "branch_momento_magico": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mare/page_tramonto_riva.webp",
          "panels": [
            {
              "id": "bmm_0",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "bmm_0_tb_0",
                  "type": "narration",
                  "text": "Favilla lo prende proprio in riva all'acqua — la schiuma fredda ai piedi, Lex sollevato di peso, ridendo."
                },
                {
                  "id": "bmm_0_tb_1",
                  "type": "narration",
                  "text": "La luce del tramonto. I capelli di Favilla — per un secondo, solo un secondo — hanno una sfumatura che non è solo arancione del sole."
                },
                {
                  "id": "bmm_0_tb_2",
                  "type": "narration",
                  "text": "Mallow la guarda da lontano. Pensa: quanto è bella."
                },
                {
                  "id": "bmm_0_tb_3",
                  "type": "narration",
                  "text": "Non capisce. Non ancora. Ma questo momento lui lo fotografa con gli occhi e non lo butterà via."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bmomen_p0"
        }
      ]
    }
