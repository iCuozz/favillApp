                  "resistenza": 5,
                  "legame": -5,
                  "segreto": 5
                }
              }
            ]
          },
          "id": "bcaffe_p1"
        }
      ]
    },
    "branch_preso_male": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mare/page_lex_preso.webp",
          "panels": [
            {
              "id": "bpm_0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bpm_0_tb_0",
                  "type": "narration",
                  "text": "Afferrato. La presa è brusca, innervosita."
                },
                {
                  "id": "bpm_0_tb_1",
                  "type": "narration",
                  "text": "Non fa male, ma Lex sente il cambio. Sente quando la mamma non è più con lui nello spazio."
                },
                {
                  "id": "bpm_0_tb_2",
                  "type": "narration",
                  "text": "Per un secondo lo sguarda di Lex si azzera."
                },
                {
                  "id": "bpm_0_tb_3",
                  "type": "thought",
                  "text": "Perfetto. Ho rotto il momento.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ],
          "id": "bpreso_p0"
        }
      ]
    },
    "branch_caffe_no": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mare/page_caffe.webp",
          "panels": [
            {
              "id": "bcn_0",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bcn_0_tb_0",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "«Oggi no.»"
                },
                {
                  "id": "bcn_0_tb_1",
                  "type": "narration",
                  "text": "Mallow non batte ciglio. Prende lui il caffè e lo finisce senza fretta, guardando il mare."
                },
                {
                  "id": "bcn_0_tb_2",
                  "type": "narration",
                  "text": "Lex guarda il caffè di Mallow. Poi guarda Favilla. Poi torna a guardare il caffè. Un'espressione di calcoli rivisti — ma non abbandonati."
                }
              ],
              "interactions": []
            }
          ],
          "id": "bcaffe_p0"
        },
