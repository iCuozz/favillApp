{
  "id": "s1_mattina_dopo",
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/s1/s1_mattina_dopo/page_0.webp",
      "panels": [
        {
          "id": "md0_0",
          "characters": [
            "favilla"
          ],
          "text_blocks": [
            {
              "id": "md0_0_tb_0",
              "type": "narration",
              "text": "5:12 del mattino. Lex ha smesso di piangere da un'ora. Mallow dorme."
            },
            {
              "id": "md0_0_tb_1",
              "type": "thought",
              "text": "E io sono qui, sveglia, a fissare il soffitto come se avesse le risposte.",
              "speaker": "favilla"
            },
            {
              "id": "md0_0_tb_2",
              "type": "narration",
              "text": "Ieri sera è successa una cosa che non so come chiamare. Non so se è un dono. Non so se è un peso."
            },
            {
              "id": "md0_0_tb_3",
              "type": "thought",
              "text": "So solo che adesso la pasta è cotta al punto giusto e mio figlio è al sicuro.",
              "speaker": "favilla"
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_mattina_dopo/page_1.webp",
      "panels": [
        {
          "id": "md1_0",
          "characters": [
            "favilla",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "md1_0_tb_0",
              "type": "narration",
              "text": "Poi Lex si sveglia. Come sempre — senza preavviso, senza trattative."
            },
            {
              "id": "md1_0_tb_1",
              "type": "dialogue",
              "speaker": "lex",
              "text": "Mmh. Mmmmh!"
            },
            {
              "id": "md1_0_tb_2",
              "type": "narration",
              "text": "Ma stavolta, quando Favilla si avvicina, lui non guarda il biberon. Non guarda il pupazzo."
            },
            {
              "id": "md1_0_tb_3",
              "type": "narration",
              "text": "La guarda lei. Con quegli occhi enormi che sembrano sapere già tutto."
            },
            {
              "id": "md1_0_tb_4",
              "type": "thought",
              "text": "Tu c'eri. Hai visto.",
              "speaker": "favilla"
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/s1/s1_mattina_dopo/page_2.webp",
      "panels": [
        {
          "id": "md2_0",
          "characters": [
            "favilla",
            "lex",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "md2_0_tb_0",
              "type": "narration",
              "text": "Poi Lex decide di agire. Alza le braccia. Le sbatte in avanti con tutta la forza che ha — ovvero quella di un budino."
            },
            {
              "id": "md2_0_tb_1",
              "type": "dialogue",
              "speaker": "lex",
              "text": "WAAAAH! Pff. WAAAAH!"
            },
            {
              "id": "md2_0_tb_2",
              "type": "narration",
              "text": "Vuole volare. È ovvio. Sta cercando di volare."
            },
            {
              "id": "md2_0_tb_3",
              "type": "narration",
              "text": "Mallow alza gli occhi dal telefono. La guarda. Guarda Lex. Aspetta la sua reazione."
            }
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "reazione_lex",
        "prompt": "",
        "options": [
          {
            "id": "respira",
            "label": "Le dita si scaldano. Cerca di restare calma.",
            "goto_branch": "branch_sorriso",
            "stat_effects": {},
            "minigame": {
              "type": "respira",
              "duration_seconds": 12,
              "tiers": [
                {
                  "min": 1,
                  "label": "Controllo totale.",
                  "goto_branch": "branch_sorriso",
                  "stat_effects": {
                    "segreto": 10,
                    "legame": 5
                  }
                },
                {
                  "min": 0,
                  "label": "Le mani scottano.",
                  "goto_branch": "branch_sudore",
                  "stat_effects": {
                    "segreto": -10,
                    "legame": 5
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "branches": {
    "branch_sorriso": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mattina_dopo/branch_sorriso.webp",
          "panels": [
            {
              "id": "bs_0",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "bs_0_tb_0",
                  "type": "narration",
                  "text": "Lex ride — quella risata piena con i due dentini. Contagiosa, inevitabile."
                },
                {
                  "id": "bs_0_tb_1",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Guardate questi due. Già alleati contro di me."
                },
                {
                  "id": "bs_0_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Sempre stato così."
                },
                {
                  "id": "bs_0_tb_3",
                  "type": "thought",
                  "text": "Il segreto è al sicuro. Per ora è ancora nostro — mio e suo.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ],
          "id": "bsorri_p0"
        }
      ]
    },
    "branch_sudore": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mattina_dopo/branch_sudore.webp",
          "panels": [
            {
              "id": "bsu_0",
              "characters": [
                "favilla",
                "lex",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "bsu_0_tb_0",
                  "type": "narration",
                  "text": "Un'ora dopo. Favilla sta cercando di fare colazione con una mano. L'altra la tiene nascosta."
                },
                {
                  "id": "bsu_0_tb_1",
                  "type": "narration",
                  "text": "Mallow alza gli occhi dal caffè."
                },
                {
                  "id": "bsu_0_tb_2",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Favilla. Le mani."
                },
                {
                  "id": "bsu_0_tb_3",
                  "type": "narration",
                  "text": "Non è una domanda. Mallow sa che c'è qualcosa che non va."
                },
                {
                  "id": "bsu_0_tb_4",
                  "type": "thought",
                  "text": "Sembravi bruciata.",
                  "speaker": "favilla"
                },
                {
                  "id": "bsu_0_tb_5",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Mi sono scottata facendo la pasta. Nulla di grave."
                },
                {
                  "id": "bsu_0_tb_6",
                  "type": "narration",
                  "text": "Lex osserva da dove sta, seduto nel seggiolone. I suoi occhi vanno da Mallow a Favilla. Dalla reazione di suo nonno. Lei sa che sa."
                },
                {
                  "id": "bsu_0_tb_7",
                  "type": "thought",
                  "text": "Ho dovuto mentire più velocemente del previsto.",
                  "speaker": "favilla"
                },
                {
                  "id": "bsu_0_tb_8",
                  "type": "narration",
                  "text": "Mallow non commenta. Ma guarda quella mano un secondo in più."
                },
                {
                  "id": "bsu_0_tb_9",
                  "type": "system",
                  "text": "MISSIONE COMPLETATA — La Mattina Dopo"
                }
              ],
              "interactions": []
            }
          ],
          "id": "bsudor_p0"
        }
      ]
    },
    "epilogue_caffe": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mattina_dopo/epilogue.webp",
          "panels": [
            {
              "id": "ep_caffe_0",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "ep_caffe_0_tb_0",
                  "type": "narration",
                  "text": "Caldo. Forte. Familiare."
                },
                {
                  "id": "ep_caffe_0_tb_1",
                  "type": "narration",
                  "text": "Per un secondo si sente quasi normale. Poi sente il vuoto — dove ieri sera c'era una tempesta, ora c'è solo silenzio."
                },
                {
                  "id": "ep_caffe_0_tb_2",
                  "type": "thought",
                  "text": "Non si scalda. Il caffè... spegne.",
                  "speaker": "favilla"
                },
                {
                  "id": "ep_caffe_0_tb_3",
                  "type": "narration",
                  "text": "Lex la guarda dalla sedia. Oggi la mamma non brilla. E non sa se preoccuparsi."
                },
                {
                  "id": "ep_caffe_0_tb_4",
                  "type": "system",
                  "text": "MISSIONE COMPLETATA — La Mattina Dopo"
                }
              ],
              "interactions": []
            }
          ],
          "id": "epilog_p0"
        }
      ]
    },
    "epilogue_no_caffe": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_mattina_dopo/epilogue.webp",
          "panels": [
            {
              "id": "ep_nocaffe_0",
              "characters": [
                "favilla",
                "mallow"
              ],
              "text_blocks": [
                {
                  "id": "ep_nocaffe_0_tb_0",
                  "type": "narration",
                  "text": "Lo lascia lì. Si volta verso la finestra."
                },
                {
                  "id": "ep_nocaffe_0_tb_1",
                  "type": "thought",
                  "text": "Se il caffè c'entra qualcosa, voglio scoprirlo con la testa lucida.",
                  "speaker": "favilla"
                },
                {
                  "id": "ep_nocaffe_0_tb_2",
                  "type": "narration",
                  "text": "Mallow alza gli occhi dal telefono. Guarda la tazzina. Guarda lei."
                },
                {
                  "id": "ep_nocaffe_0_tb_3",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Non bevi il caffè?"
                },
                {
                  "id": "ep_nocaffe_0_tb_4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Stamattina no."
                },
                {
                  "id": "ep_nocaffe_0_tb_5",
                  "type": "narration",
                  "text": "Pausa. Mallow non dice nient'altro. Ma non toglie gli occhi da lei."
                },
                {
                  "id": "ep_nocaffe_0_tb_6",
                  "type": "narration",
                  "text": "Lex approva, a modo suo. Non sa che ha appena complicato tutto."
                },
                {
                  "id": "ep_nocaffe_0_tb_7",
                  "type": "system",
                  "text": "MISSIONE COMPLETATA — La Mattina Dopo"
                }
              ],
              "interactions": []
            }
          ],
          "id": "epilog_p0"
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "background": "assets/episodes/s1/s1_mattina_dopo/epilogue.webp",
        "panels": [
          {
            "id": "md_ep_0",
            "characters": [
              "favilla"
            ],
            "text_blocks": [
              {
                "id": "md_ep_0_tb_0",
                "type": "narration",
                "text": "Alle 7:30 Favilla è in piedi, Lex sul fianco, Mallow già in call."
              },
              {
                "id": "md_ep_0_tb_1",
                "type": "narration",
                "text": "Tutto uguale a ieri. Tutto diverso da ieri."
              },
              {
                "id": "md_ep_0_tb_2",
                "type": "thought",
                "text": "Nova Tutinia non sa ancora cosa si nasconde al terzo piano di Via delle Vesciche e dei Brufoli 18.",
                "speaker": "favilla"
              },
              {
                "id": "md_ep_0_tb_3",
                "type": "narration",
                "text": "Il caffè è sul bancone. Caldo. Come sempre."
              }
            ],
            "interactions": []
          }
        ],
        "choice": {
          "id": "caffe_choice",
          "prompt": "Favilla fissa la tazzina. Lo prende?",
          "options": [
            {
              "id": "caffe_si",
              "label": "Lo beve d'un fiato. Come ogni mattina.",
              "hint": "Il caffè smorza la Scintilla. Ma il corpo chiede tregua.",
              "goto_branch": "epilogue_caffe",
              "stat_effects": {
                "scintille": -8,
                "resistenza": 1
              }
            },
            {
              "id": "caffe_no",
              "label": "Lo lascia lì. Stamattina, meglio di no.",
              "hint": "Mallow la guarda. Favilla non beve mai il caffè freddo.",
              "goto_branch": "epilogue_no_caffe",
              "stat_effects": {
                "resistenza": 10,
                "segreto": -5,
                "legame": -5
              }
            }
          ]
        },
        "id": "ep_p0"
      }
    ]
  }
}