    }
  ],
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/s1/s1_scuola_1/page_0.webp",
      "panels": [
        {
          "id": "sc1_0_0",
          "characters": [
            "favilla"
          ],
          "text_blocks": [
            {
              "id": "sc1_0_0_tb_0",
              "type": "narration",
              "text": "Scuola elementare di Nova Tutinia. 7:55 del mattino."
            },
            {
              "id": "sc1_0_0_tb_1",
              "type": "thought",
              "text": "Era stanchezza. Era solo stanchezza. Queste cose non esistono.",
              "speaker": "favilla"
            },
            {
              "id": "sc1_0_0_tb_2",
              "type": "narration",
              "text": "I capelli fremono per un secondo. Favilla li stringe in una coda e li ignora."
            },
            {
              "id": "sc1_0_0_tb_3",
              "type": "thought",
              "text": "Giornata normale. Testa bassa. Sorriso fisso.",
              "speaker": "favilla"
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/s1/s1_scuola_1/page_1.webp",
      "panels": [
        {
          "id": "sc1_1_0",
          "characters": [
            "favilla",
            "corvi"
          ],
          "text_blocks": [
            {
              "id": "sc1_1_0_tb_0",
              "type": "narration",
              "text": "Poi arriva lei. Tacco dodici, cartella di pelle, sguardo da revisione dei conti."
            },
            {
              "id": "sc1_1_0_tb_1",
              "type": "dialogue",
              "speaker": "corvi",
              "text": "Ispezione straordinaria. Entro le 8:30 voglio la palestra libera e i magazzini riordinati. Tutto."
            },
            {
              "id": "sc1_1_0_tb_2",
              "type": "narration",
              "text": "In palestra ci sono scaffali metallici da trenta chili l'uno. In magazzino, anni di cartacce e mobili rotti."
            },
            {
              "id": "sc1_1_0_tb_3",
              "type": "dialogue",
              "speaker": "corvi",
              "text": "Ha capito o devo ripetere?"
            },
            {
              "id": "sc1_1_0_tb_4",
              "type": "thought",
              "text": "Trentacinque minuti. Da sola.",
              "speaker": "favilla"
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/s1/s1_scuola_1/page_2.webp",
      "panels": [
        {
          "id": "sc1_2_0",
          "characters": [
            "favilla"
          ],
          "text_blocks": [
            {
              "id": "sc1_2_0_tb_0",
              "type": "narration",
              "text": "Favilla spinge. Trascina. Sudore. Respiro corto. Un minuto. Dieci minuti. Venti."
            },
            {
              "id": "sc1_2_0_tb_1",
              "type": "thought",
              "text": "Non ce la faccio. Non ce la faccio. Non ce la—",
              "speaker": "favilla"
            },
            {
              "id": "sc1_2_0_tb_2",
              "type": "narration",
              "text": "Poi qualcosa dentro di lei si rompe. O si apre."
            },
            {
              "id": "sc1_2_0_tb_3",
              "type": "narration",
              "text": "Venti secondi dopo, la palestra è perfetta. I magazzini sono in ordine. Lei è in piedi nel silenzio, con le mani che tremano."
            },
            {
              "id": "sc1_2_0_tb_4",
              "type": "thought",
              "text": "Cosa ho fatto. Cosa ho fatto. Cosa ho—",
              "speaker": "favilla"
            },
            {
              "id": "sc1_2_0_tb_5",
              "type": "narration",
              "text": "Abbassa gli occhi. Sul fianco della camicetta, due bruciature scure. Forma di dita."
            }
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "scottature_choice",
        "prompt": "Le bruciature sono visibili. La Corvi torna tra pochi minuti.",
        "options": [
          {
            "id": "bagno",
            "label": "Corre in bagno. Ha un cambio nello zaino.",
            "hint": "Nessuno vede i vestiti. Ma la Corvi nota l'assenza.",
            "goto_branch": "branch_bagno",
            "stat_effects": {
              "segreto": 10,
              "resistenza": -10
            },
            "set_flags": {
              "shirt_in_backpack": true
            }
          },
          {
            "id": "finge_niente",
            "label": "Rimane. Fa finta di niente.",
            "hint": "La faccia tosta regge. Ma qualcuno guarda.",
            "goto_branch": "branch_finge",
            "stat_effects": {
              "segreto": -10,
              "resistenza": 10
            },
            "set_flags": {
              "shirt_in_backpack": false
            }
          }
        ]
      }
    }
  ],
  "branches": {
    "intro_caffe_effect": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_scuola_1/page_0.webp",
          "panels": [
            {
              "id": "caffe_intro_0",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "caffe_intro_tb_0",
                  "type": "narration",
                  "text": "7:55. Le porte della scuola. Come sempre."
                },
                {
                  "id": "caffe_intro_tb_1",
                  "type": "thought",
                  "text": "Il caffè. Il caffè è stato un errore.",
                  "speaker": "favilla"
                },
                {
                  "id": "caffe_intro_tb_2",
                  "type": "narration",
                  "text": "I capelli non fremono più. Dove ieri c'era una brace pronta ad accendersi, ora c'è solo cenere fredda."
                },
                {
                  "id": "caffe_intro_tb_3",
                  "type": "thought",
                  "text": "Testa bassa. Sorriso fisso. Niente di strano. Tutto normalissimo.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ],
          "id": "icaffe_p0"
        }
      ]
    },
    "branch_bagno": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_scuola_1/branch_bagno.webp",
          "panels": [
            {
              "id": "bb_0",
              "characters": [
                "favilla",
                "corvi"
              ],
              "text_blocks": [
                {
                  "id": "bb_0_tb_0",
                  "type": "narration",
                  "text": "Cambio veloce. Respiro. Sorriso. Favilla rientra in palestra trentatré secondi dopo."
                },
                {
                  "id": "bb_0_tb_1",
                  "type": "dialogue",
                  "speaker": "corvi",
                  "text": "Dov'era?"
                },
                {
                  "id": "bb_0_tb_2",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Bagno. Femminile. Necessità."
                },
                {
                  "id": "bb_0_tb_3",
                  "type": "narration",
                  "text": "La Corvi ispeziona la palestra. Annuisce con la stessa calore di un verbale fiscale."
                },
                {
                  "id": "bb_0_tb_4",
                  "type": "dialogue",
                  "speaker": "corvi",
                  "text": "Accettabile."
                },
                {
                  "id": "bb_0_tb_5",
                  "type": "thought",
                  "text": "I vestiti bruciati sono in fondo allo zaino. Il segreto è al sicuro. Per ora.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ],
          "id": "bbagno_p0"
        }
      ]
    },
    "branch_finge": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_scuola_1/branch_finge.webp",
          "panels": [
            {
              "id": "bf_0",
              "characters": [
                "favilla",
                "corvi",
                "collega"
              ],
              "text_blocks": [
                {
                  "id": "bf_0_tb_0",
                  "type": "narration",
                  "text": "La Corvi entra. Ispeziona. Annuisce. Se ne va senza una parola."
                },
                {
                  "id": "bf_0_tb_1",
                  "type": "narration",
                  "text": "Ma in corridoio, una collega si avvicina."
                },
                {
                  "id": "bf_0_tb_2",
                  "type": "dialogue",
                  "speaker": "collega",
                  "text": "Favilla, ti sei fatta del male? La camicia..."
                },
                {
                  "id": "bf_0_tb_3",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Il ferro da stiro. Stamattina ero mezza addormentata."
                },
                {
                  "id": "bf_0_tb_4",
                  "type": "narration",
                  "text": "La collega ride. Le crede. Ma ci ha guardato un secondo troppo."
                },
                {
                  "id": "bf_0_tb_5",
                  "type": "thought",
                  "text": "Bugia numero due. Le stavo contando?",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ],
          "id": "bfinge_p0"
        }
      ]
    },
    "intro_segreto_pericolo": {
      "pages": [
        {
          "background": "assets/episodes/s1/s1_scuola_1/page_0.webp",
          "panels": [
            {
              "id": "sp_segreto_0",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "sp_segreto_0_tb_0",
                  "type": "narration",
                  "text": "Il cancello della scuola è davanti a lei. Ma la mattina è già iniziata — in salita."
                },
                {
                  "id": "sp_segreto_0_tb_1",
                  "type": "narration",
                  "text": "Mallow è stato silenzioso tutto il tempo. Non il silenzio normale, quello dei giorni in cui lavora concentrato. Un silenzio diverso. Attendista."
                },
                {
                  "id": "sp_segreto_0_tb_2",
                  "type": "narration",
                  "text": "Le ha stretto la mano un secondo in più, quando è scesa dalla macchina. Come se aspettasse che lei dicesse qualcosa — e lei ha aperto bocca, e ha chiuso bocca, e niente."
                },
                {
                  "id": "sp_segreto_0_tb_3",
                  "type": "thought",
                  "text": "Sa che c'è qualcosa. Non sa cosa. Ma aspetta. E aspettare, a volte, è peggio che chiedere.",
                  "speaker": "favilla"
                }
              ]
            }
          ],
          "id": "isegre_p0"
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "background": "assets/episodes/s1/s1_scuola_1/epilogue.webp",
        "panels": [
          {
            "id": "sc1_ep_0",
            "characters": [
              "favilla"
            ],
            "text_blocks": [
              {
                "id": "sc1_ep_0_tb_0",
                "type": "narration",
                "text": "End of shift. Favilla sits on the wall outside school. Looks at her hands."
              },
              {
                "id": "sc1_ep_0_tb_1",
                "type": "thought",
                "text": "It wasn't tiredness. It wasn't a dream. It was real.",
                "speaker": "favilla"
              },
              {
                "id": "sc1_ep_0_tb_2",
                "type": "narration",
                "text": "For the first time since last night, she stops convincing herself otherwise."
              },
              {
                "id": "sc1_ep_0_tb_3",
                "type": "thought",
                "text": "And now?",
                "speaker": "favilla"
              },
              {
                "id": "sc1_ep_0_tb_4",
                "type": "system",
                "text": "MISSION COMPLETE — A Normal Day"
              }
            ],
            "interactions": []
          }
        ],
        "id": "ep_p0"
      }
    ]
  }
}