                  "goto_branch": "branch_tardi_parziale"
                },
                {
                  "min": 0,
                  "label": "Missed!",
                  "stat_effects": {},
                  "goto_branch": "branch_tardi_mancato"
                }
              ]
            }
          },
          {
            "id": "prima",
            "label": "Looks up from her phone. Looks at Lex. Something isn't right.",
            "hint": "That face. That face is not innocent.",
            "goto_branch": "branch_prima",
            "stat_effects": {
              "segreto": 10,
              "legame": -10
            }
          }
        ]
      }
    }
  ],
  "branches": {
    "intro_mani_calde": {
      "pages": [
        {
          "id": "imc_0",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_entry.webp",
          "panels": [
            {
              "id": "imc_0_p0",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "imc_0_p0_tb_0",
                  "type": "narration",
                  "text": "Favilla's hands are already warm when she takes the trolley at the entrance to the IperPassata."
                },
                {
                  "id": "imc_0_p0_tb_1",
                  "type": "thought",
                  "text": "Again. More and more.",
                  "speaker": "favilla"
                },
                {
                  "id": "imc_0_p0_tb_2",
                  "type": "narration",
                  "text": "She grips the plastic handle. The heat drops a few degrees. Enough to seem normal. Enough for today."
                },
                {
                  "id": "imc_0_p0_tb_3",
                  "type": "thought",
                  "text": "Supermarket. List. Home. Simple.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_tardi": {
      "pages": [
        {
          "id": "bt_0",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_tardi_0.webp",
          "panels": [
            {
              "id": "bt_0_p0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bt_0_p0_tb_0",
                  "type": "narration",
                  "text": "The weapon is ready. Lex aims it at the shelf."
                },
                {
                  "id": "bt_0_p0_tb_1",
                  "type": "narration",
                  "text": "Three seconds of total silence."
                },
                {
                  "id": "bt_0_p0_tb_2",
                  "type": "dialogue",
                  "speaker": "lex",
                  "text": "HA!"
                },
                {
                  "id": "bt_0_p0_tb_3",
                  "type": "narration",
                  "text": "A jar of tomatoes goes flying. Drags two more. Those two drag four more. In a second and a half, half the tinned tomato aisle is on the floor."
                },
                {
                  "id": "bt_0_p0_tb_4",
                  "type": "narration",
                  "text": "The noise is epic."
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "id": "bt_1",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_tardi_1.webp",
          "panels": [
            {
              "id": "bt_1_p0",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "bt_1_p0_tb_0",
                  "type": "narration",
                  "text": "Favilla turns around."
                },
                {
                  "id": "bt_1_p0_tb_1",
                  "type": "narration",
                  "text": "The shock is immediate. The jars. Lex. The noise. Three people turning. A woman startling."
                },
                {
                  "id": "bt_1_p0_tb_2",
                  "type": "narration",
                  "text": "Favilla's hands — already warm — become scorching."
                },
                {
                  "id": "bt_1_p0_tb_3",
                  "type": "narration",
                  "text": "A flash."
                },
                {
                  "id": "bt_1_p0_tb_4",
                  "type": "narration",
                  "text": "A single, very brief flash of light in her hair — then darkness."
                },
                {
                  "id": "bt_1_p0_tb_5",
                  "type": "narration",
                  "text": "The jars are back on the shelf. Aligned. Perfect. Nobody knows how."
                },
                {
                  "id": "bt_1_p0_tb_6",
                  "type": "narration",
                  "text": "It took less than a second. Favilla is already still, list in hand, as if nothing happened."
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "id": "bt_2",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_tardi_2.webp",
          "panels": [
            {
              "id": "bt_2_p0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bt_2_p0_tb_0",
                  "type": "narration",
                  "text": "Lex saw it."
                },
                {
                  "id": "bt_2_p0_tb_1",
                  "type": "narration",
                  "text": "The whole scene. Front row. From the trolley seat, prime position."
                },
                {
                  "id": "bt_2_p0_tb_2",
                  "type": "narration",
                  "text": "Under the little bib, a micro-fist clenched in a gesture of victory."
                },
                {
                  "id": "bt_2_p0_tb_3",
                  "type": "dialogue",
                  "speaker": "lex",
                  "text": "Ooooh."
                },
                {
                  "id": "bt_2_p0_tb_4",
                  "type": "narration",
                  "text": "Favilla looks at him. Searching for something in his face. Something that betrays understanding."
                },
                {
                  "id": "bt_2_p0_tb_5",
                  "type": "thought",
                  "text": "No. He didn't understand. He's just a baby. He saw lights, noise. It scared him. It happens.",
                  "speaker": "favilla"
                },
                {
                  "id": "bt_2_p0_tb_6",
                  "type": "narration",
                  "text": "Lex looks her straight in the eyes and smiles."
                },
                {
                  "id": "bt_2_p0_tb_7",
                  "type": "narration",
                  "text": "Favilla doesn't know that smile is the satisfaction of a plan that worked."
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_prima": {
      "pages": [
        {
          "id": "bp_0",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_prima_0.webp",
          "panels": [
            {
              "id": "bp_0_p0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bp_0_p0_tb_0",
                  "type": "narration",
                  "text": "Favilla looks up."
                },
                {
                  "id": "bp_0_p0_tb_1",
                  "type": "narration",
                  "text": "Lex is motionless. Tongue out. Teddy bear in hand. Aimed at the shelf at a disturbing angle."
                },
                {
                  "id": "bp_0_p0_tb_2",
                  "type": "thought",
                  "text": "No.",
                  "speaker": "favilla"
                },
                {
                  "id": "bp_0_p0_tb_3",
                  "type": "narration",
                  "text": "Two quick steps. Favilla's hand is on the bear before it launches. Silent extraction. Professional."
                },
                {
                  "id": "bp_0_p0_tb_4",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "No."
                },
                {
                  "id": "bp_0_p0_tb_5",
                  "type": "narration",
                  "text": "Lex stares at her."
                },
                {
                  "id": "bp_0_p0_tb_6",
                  "type": "narration",
                  "text": "He stares at it with the face of someone who's just watched their masterpiece destroyed."
                },
                {
                  "id": "bp_0_p0_tb_7",
                  "type": "dialogue",
                  "speaker": "lex",
                  "text": "Eh."
                },
                {
                  "id": "bp_0_p0_tb_8",
                  "type": "thought",
                  "text": "Exactly, 'eh'. Deferred.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "id": "bp_1",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_prima_1.webp",
          "panels": [
            {
              "id": "bp_1_p0",
              "characters": [
                "favilla",
                "carmela"
              ],
              "text_blocks": [
                {
                  "id": "bp_1_p0_tb_0",
                  "type": "narration",
                  "text": "A voice behind her."
                },
                {
                  "id": "bp_1_p0_tb_1",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "What a beautiful baby."
                },
                {
                  "id": "bp_1_p0_tb_2",
                  "type": "narration",
                  "text": "Favilla turns. An elderly woman, white hair and eyes too alert for that hour of the morning, has appeared from around the corner of the shelf. A nearly empty basket on her arm."
                },
                {
                  "id": "bp_1_p0_tb_3",
                  "type": "narration",
                  "text": "She doesn't look at Lex."
                },
                {
                  "id": "bp_1_p0_tb_4",
                  "type": "narration",
                  "text": "She looks at Favilla's hands."
                },
                {
                  "id": "bp_1_p0_tb_5",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "Smart little one."
                },
                {
                  "id": "bp_1_p0_tb_6",
                  "type": "narration",
                  "text": "A pause. Brief. Surgical."
                },
                {
                  "id": "bp_1_p0_tb_7",
                  "type": "dialogue",
                  "speaker": "carmela",
                  "text": "Just like mummy."
                },
                {
                  "id": "bp_1_p0_tb_8",
                  "type": "narration",
                  "text": "She takes the bottle of tomato sauce from the shelf. Puts it in her basket. Leaves without turning around."
                },
                {
                  "id": "bp_1_p0_tb_9",
                  "type": "thought",
                  "text": "Who is she?",
                  "speaker": "favilla"
                },
                {
                  "id": "bp_1_p0_tb_10",
                  "type": "thought",
                  "text": "Why was she looking at my hands?",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "epilogue_ottimista": {
      "pages": [
        {
          "id": "eo_0",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_epilogo.webp",
          "panels": [
            {
              "id": "eo_0_p0",
              "characters": [
                "favilla",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "eo_0_p0_tb_0",
                  "type": "narration",
                  "text": "Outside the IperPassata. Saturday sun. Lex in the pushchair, dangerously quiet."
                },
                {
                  "id": "eo_0_p0_tb_1",
                  "type": "narration",
                  "text": "Favilla looks at him. Thinks about everything that's happened. Then, without meaning to, a half-laugh escapes her."
                },
                {
                  "id": "eo_0_p0_tb_2",
                  "type": "thought",
                  "text": "A seven-month-old baby just tried to make me transform in the pasta aisle.",
                  "speaker": "favilla"
                },
                {
                  "id": "eo_0_p0_tb_3",
                  "type": "thought",
                  "text": "With a fabric bear.",
                  "speaker": "favilla"
                },
                {
                  "id": "eo_0_p0_tb_4",
                  "type": "narration",
                  "text": "Lex looks at her. He still has the same serious general's expression. Studies the environment. Assesses. Plans the next attempt."
                },
                {
                  "id": "eo_0_p0_tb_5",
                  "type": "thought",
                  "text": "It'll get better. I'm learning.",
                  "speaker": "favilla"
                },
                {
                  "id": "eo_0_p0_tb_6",
                  "type": "thought",
                  "text": "Him too.",
                  "speaker": "favilla"
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "epilogue_cauta": {
      "pages": [
        {
          "id": "ec_0",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_epilogo.webp",
          "panels": [
            {
              "id": "ec_0_p0",
              "characters": [
                "favilla"
              ],
              "text_blocks": [
                {
                  "id": "ec_0_p0_tb_0",
                  "type": "narration",
                  "text": "Outside the IperPassata. Favilla doesn't see the sun. She sees that woman."
                },
                {
                  "id": "ec_0_p0_tb_1",
                  "type": "thought",
                  "text": "She was looking at my hands. Not Lex. Not the jars. My hands.",
                  "speaker": "favilla"
                },
                {
                  "id": "ec_0_p0_tb_2",
                  "type": "thought",
                  "text": "As if he already knows what to look for.",
                  "speaker": "favilla"
                },
                {
                  "id": "ec_0_p0_tb_3",
                  "type": "narration",
                  "text": "Lex is in the pushchair, strangely quiet. Eyes half-closed. The expression of someone reconsidering a plan and seeing where it went wrong."
                },
                {
                  "id": "ec_0_p0_tb_4",
                  "type": "thought",
                  "text": "I need to be more careful. About everything.",
                  "speaker": "favilla"
                },
                {
                  "id": "ec_0_p0_tb_5",
                  "type": "narration",
                  "text": "They both have the same expression."
                },
                {
                  "id": "ec_0_p0_tb_6",
                  "type": "narration",
                  "text": "Neither of them is done yet."
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
