                  "type": "narration"
                },
                {
                  "text": "Three jars fall. A dull thud. One rolls to the middle of the aisle.",
                  "type": "narration"
                },
                {
                  "text": "Favilla turns around.",
                  "type": "narration"
                },
                {
                  "text": "Jars on the floor. Lex still holding the dummy cord. That face.",
                  "type": "narration"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "id": "btp_1",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_bt_1.webp",
          "panels": [
            {
              "id": "btp_1_p0",
              "characters": [],
              "text_blocks": [
                {
                  "text": "Favilla's hands warm up. Just for a moment. Not enough.",
                  "type": "narration"
                },
                {
                  "text": "A woman with a bag stops and looks at the jars.",
                  "type": "narration"
                },
                {
                  "text": "Then looks at Lex. Then Favilla.",
                  "type": "narration"
                },
                {
                  "text": "Favilla feels her hair — just the tips — tremble slightly. Like when there's too much electricity in the air.",
                  "type": "narration"
                }
              ],
              "interactions": []
            }
          ],
          "choice": {
