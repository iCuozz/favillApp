                "hint": "The tips of her hair keep trembling. Only Lex notices.",
                "goto_branch": "branch_parziale_sistema",
                "stat_effects": {
                  "segreto": -3,
                  "resistenza": -3
                }
              },
              {
                "id": "opt_lascia",
                "label": "Leaves them there. Takes Lex, turns the trolley and goes.",
                "hint": "It's not her shelf. It's not her problem.",
                "goto_branch": "branch_parziale_lascia",
                "stat_effects": {
                  "resistenza": -5
                }
              }
            ]
          }
        }
      ]
    },
    "branch_tardi_mancato": {
      "id": "branch_tardi_mancato",
      "skips_epilogue": true,
      "pages": [
        {
          "id": "btm_0",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_bt_0.webp",
          "panels": [
            {
              "id": "btm_0_p0",
              "characters": [],
              "text_blocks": [
                {
                  "text": "The bear shoots through the air. Clears it.",
                  "type": "narration"
                },
                {
                  "text": "It lands softly on the floor a metre from the shelves.",
                  "type": "narration"
                },
                {
                  "text": "Silence. The shelves are intact. The jars still.",
                  "type": "narration"
                },
                {
                  "text": "Favilla didn't even turn around.",
                  "type": "narration"
                }
              ],
              "interactions": []
            }
          ]
        },
        {
          "id": "btm_1",
          "background": "assets/episodes/s1/s1_spesa_sabato/page_bt_0.webp",
          "panels": [
            {
