{
  "id": "prologo",
  "pages": [
    {
      "index": 0,
      "background": "assets/episodes/prologo/page_0.webp",
      "panels": [
        {
          "id": "pr0_0",
          "characters": [
            "favilla",
            "bambini"
          ],
          "text_blocks": [
            {
              "id": "pr0_0_tb_0",
              "type": "narration",
              "text": "Nova Tutinia, scuola elementare. Di giorno sono Favilla, collaboratrice scolastica. Gestisco 50 piccoli uragani ogni giorno."
            },
            {
              "id": "pr0_0_tb_1",
              "type": "dialogue",
              "speaker": "bimbo_1",
              "text": "Favilla! Hai visto la mia gomma?!?"
            },
            {
              "id": "pr0_0_tb_2",
              "type": "dialogue",
              "speaker": "bimbo_2",
              "text": "È mia! L'ho trovata prima io!"
            },
            {
              "id": "pr0_0_tb_3",
              "type": "dialogue",
              "speaker": "favilla",
              "text": "Ragazzi...attenti che la gomma è magica, se litigate vi cancella i giocattoli!"
            },
            {
              "id": "pr0_0_tb_4",
              "type": "narration",
              "text": "Se sapeste cosa mi aspetta a casa..."
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 1,
      "background": "assets/episodes/prologo/page_1.webp",
      "panels": [
        {
          "id": "pr1_0",
          "characters": [
            "favilla",
            "lex",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "pr1_0_tb_0",
              "type": "narration",
              "text": "Poi c'è casa. Il vero campo di battaglia si chiama Lex. Sette mesi e mezzo di puro, adorabile caos."
            },
            {
              "id": "pr1_0_tb_1",
              "type": "dialogue",
              "speaker": "lex",
              "text": "Mmmmh! Waaah! AHHH!"
            },
            {
              "id": "pr1_0_tb_2",
              "type": "dialogue",
              "speaker": "favilla",
              "text": "Bubbà! Lex piccolo, un disastro alla volta!"
            },
            {
              "id": "pr1_0_tb_3",
              "type": "narration",
              "text": "Lui è Mallow, mio marito. Programma software, ma spesso manda in crash tutta la casa."
            },
            {
              "id": "pr1_0_tb_4",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Ho una call tra cinque minuti..."
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 2,
      "background": "assets/episodes/prologo/page_2.webp",
      "panels": [
        {
          "id": "pr2_0",
          "characters": [
            "favilla",
            "lex",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "pr2_0_tb_0",
              "type": "narration",
              "text": "Pappe esplosive, panni infiniti, Lex che lancia qualsiasi cosa a portata di mano."
            },
            {
              "id": "pr2_0_tb_1",
              "type": "dialogue",
              "speaker": "favilla",
              "text": "Lex, il cucchiaino si mangia, non si lancia!"
            },
            {
              "id": "pr2_0_tb_2",
              "type": "narration",
              "text": "Mallow è in call. Il portatile occupa metà tavolo. La pasta è sul fuoco."
            },
            {
              "id": "pr2_0_tb_3",
              "type": "thought",
              "text": "Respira. Ce la fai. Sei una professionista del caos."
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 3,
      "background": "assets/episodes/prologo/page_3.webp",
      "panels": [
        {
          "id": "pr3_0",
          "characters": [
            "favilla",
            "lex",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "pr3_0_tb_0",
              "type": "narration",
              "text": "Poi arriva quel momento. Quello in cui tutto accade insieme."
            },
            {
              "id": "pr3_0_tb_1",
              "type": "narration",
              "text": "La pasta trabocca. Il telefono suona. Mallow: \"Mi senti? La linea è pessima.\""
            },
            {
              "id": "pr3_0_tb_2",
              "type": "narration",
              "text": "E Lex — Lex si sporge. Troppo. Dal sediolone."
            },
            {
              "id": "pr3_0_tb_3",
              "type": "thought",
              "text": "No. No no no—"
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 4,
      "background": "assets/episodes/prologo/page_4.webp",
      "panels": [
        {
          "id": "pr4_0",
          "characters": [
            "favilla_blaze",
            "lex"
          ],
          "text_blocks": [
            {
              "id": "pr4_0_tb_0",
              "type": "narration",
              "text": "Succede in un lampo. Gli occhiali spariscono. I capelli diventano luce. Una forza che non ha mai sentito prima le attraversa il corpo."
            },
            {
              "id": "pr4_0_tb_1",
              "type": "narration",
              "text": "Lex è al sicuro. La cucina è in ordine. Mallow è ancora in call."
            },
            {
              "id": "pr4_0_tb_2",
              "type": "narration",
              "text": "Il mondo non si è accorto di niente."
            },
            {
              "id": "pr4_0_tb_3",
              "type": "narration",
              "text": "Tranne Lex."
            },
            {
              "id": "pr4_0_tb_4",
              "type": "narration",
              "text": "Lex la fissa. Occhi spalancati. Poi ride — quella risata piena degli unici due dentini in basso che ha."
            },
            {
              "id": "pr4_0_tb_5",
              "type": "thought",
              "text": "Sa. Non può dirlo. Ma sa."
            }
          ],
          "interactions": []
        }
      ]
    },
    {
      "index": 5,
      "background": "assets/episodes/prologo/page_carmela.webp",
      "panels": [
        {
          "id": "pr5_carmela_0",
          "characters": [
            "carmela"
          ],
          "text_blocks": [
            {
              "id": "pr5_carmela_0_tb_0",
              "type": "narration",
              "text": "Dall'altra parte della strada, una finestra buia."
            },
            {
              "id": "pr5_carmela_0_tb_1",
              "type": "narration",
              "text": "Nel buio, qualcosa si muove."
            },
            {
              "id": "pr5_carmela_0_tb_2",
              "type": "narration",
              "text": "Due occhi si aprono di scatto."
            },
            {
              "id": "pr5_carmela_0_tb_3",
              "type": "narration",
              "text": "Fermi."
            },
            {
              "id": "pr5_carmela_0_tb_4",
              "type": "narration",
              "text": "Svegli."
            }
          ]
        }
      ]
    },
    {
      "index": 6,
      "background": "assets/episodes/prologo/page_4.webp",
      "panels": [
        {
          "id": "pr5_0",
          "characters": [
            "favilla",
            "mallow"
          ],
          "text_blocks": [
            {
              "id": "pr5_0_tb_0",
              "type": "narration",
              "text": "Mallow chiude la call. Entra in cucina. Si guarda intorno."
            },
            {
              "id": "pr5_0_tb_1",
              "type": "dialogue",
              "speaker": "mallow",
              "text": "Va tutto bene? Sembrava casino, da là dentro."
            },
            {
              "id": "pr5_0_tb_2",
              "type": "thought",
              "text": "Cosa gli dico?"
            }
          ],
          "interactions": []
        }
      ],
      "choice": {
        "id": "prima_scelta",
        "prompt": "Mallow ti fissa. Cosa rispondi?",
        "options": [
          {
            "id": "bugia",
            "label": "\"Sì. Pasta quasi pronta.\"",
            "hint": "Prima bugia. Segreto al sicuro — per ora.",
            "goto_branch": "branch_segreto",
            "stat_effects": {
              "segreto": 10,
              "legame": -5
            }
          },
          {
            "id": "mezzo_vero",
            "label": "\"Ho avuto uno strano momento...\"",
            "hint": "Mallow è curioso. Il segreto trema.",
            "goto_branch": "branch_legame",
            "stat_effects": {
              "segreto": -10,
              "legame": 10
            }
          }
        ]
      }
    }
  ],
  "branches": {
    "branch_segreto": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/prologo/page_4.webp",
          "panels": [
            {
              "id": "bs_0",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bs_0_tb_0",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Ok! Bene. Quanto manca?"
                },
                {
                  "id": "bs_0_tb_1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Dieci minuti."
                },
                {
                  "id": "bs_0_tb_2",
                  "type": "narration",
                  "text": "Lex la guarda. Sorride di nuovo. Solo lei capisce cosa significa."
                },
                {
                  "id": "bs_0_tb_3",
                  "type": "thought",
                  "text": "Il segreto è mio. E suo. Solo nostro."
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    },
    "branch_legame": {
      "pages": [
        {
          "index": 0,
          "background": "assets/episodes/prologo/page_4.webp",
          "panels": [
            {
              "id": "bl_0",
              "characters": [
                "favilla",
                "mallow",
                "lex"
              ],
              "text_blocks": [
                {
                  "id": "bl_0_tb_0",
                  "type": "dialogue",
                  "speaker": "mallow",
                  "text": "Strano come?"
                },
                {
                  "id": "bl_0_tb_1",
                  "type": "dialogue",
                  "speaker": "favilla",
                  "text": "Niente. Stanchezza. Dai, siediti."
                },
                {
                  "id": "bl_0_tb_2",
                  "type": "narration",
                  "text": "Mallow la guarda un secondo di troppo. Poi annuisce."
                },
                {
                  "id": "bl_0_tb_3",
                  "type": "thought",
                  "text": "Quasi. Quasi gli ho detto tutto."
                }
              ],
              "interactions": []
            }
          ]
        }
      ]
    }
  },
  "epilogue": {
    "pages": [
      {
        "index": 0,
        "background": "assets/episodes/prologo/page_4.webp",
        "panels": [
          {
            "id": "ep_0",
            "characters": [
              "favilla"
            ],
            "text_blocks": [
              {
                "id": "ep_0_tb_0",
                "type": "narration",
                "text": "Quella sera, mentre Lex dorme e Mallow guarda il suo schermo, Favilla si siede sul bordo del letto."
              },
              {
                "id": "ep_0_tb_1",
                "type": "thought",
                "text": "Cosa sono diventata?"
              },
              {
                "id": "ep_0_tb_2",
                "type": "narration",
                "text": "Dall'altra parte della città, Nova Tutinia dorme. Ancora per poco."
              },
              {
                "id": "ep_0_tb_3",
                "type": "system",
                "text": "FINE PROLOGO — Stagione 1: Alba Strana"
              }
            ],
            "interactions": []
          }
        ]
      }
    ]
  }
}