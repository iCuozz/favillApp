#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# pre-commit: blocca il commit se vengono modificati file narrativi
# senza aggiornare la documentazione Obsidian nelle ultime GRACE secondi.
# Esegue anche il narrative-flow-checker su ogni commit che tocca episodi JSON.
#
# File considerati "narrativi":
#   lib/widgets/minigame_*.dart
#   lib/main.dart
#   lib/models/comic_data.dart
#   assets/data/quests/**/*.json
#
# Doc Obsidian monitorati (via symlink in docs/):
#   docs/NARRATIVE_BIBLE.md
#   docs/MAPPA_NARRATIVA.md
#   docs/LIBRO_DEI_MONDI.md
#   docs/IDEE_FUTURE.md
#
# Override: git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

ROOT="$(git rev-parse --show-toplevel)"
GRACE=3600  # 60 minuti di grace period

DOC_FILES=(
  "$ROOT/docs/NARRATIVE_BIBLE.md"
  "$ROOT/docs/MAPPA_NARRATIVA.md"
  "$ROOT/docs/LIBRO_DEI_MONDI.md"
  "$ROOT/docs/IDEE_FUTURE.md"
)

STAGED=$(git diff --cached --name-only)
NARRATIVE=$(echo "$STAGED" | grep -E \
  "^(lib/widgets/minigame_|lib/main\.dart|lib/models/comic_data\.dart|assets/data/quests/)")

if [ -z "$NARRATIVE" ]; then
  exit 0
fi

# ─── JSON validation ─────────────────────────────────────────────────────────
JSON_FILES=$(echo "$STAGED" | grep "\.json$")
if [ -n "$JSON_FILES" ]; then
  JSON_ERRORS=0
  while IFS= read -r f; do
    if [ -f "$ROOT/$f" ]; then
      ERR=$(python3 -c "import json,sys; json.load(open('$ROOT/$f'))" 2>&1)
      if [ $? -ne 0 ]; then
        echo ""
        echo "❌  JSON non valido: $f"
        echo "    $ERR" | sed 's/^/    /'
        JSON_ERRORS=1
      fi
    fi
  done <<< "$JSON_FILES"
  if [ $JSON_ERRORS -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  🚨  JSON MALFORMATO — commit bloccato                      ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  Correggi i file JSON elencati sopra e riprova.             ║"
    echo "║  Override: git commit --no-verify                           ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    exit 1
  fi
fi

# ─── narrative-flow-checker ──────────────────────────────────────────────────
QUEST_CHANGES=$(echo "$STAGED" | grep -E "^assets/data/quests/")
ENGINE_CHANGES=$(echo "$STAGED" | grep -E "^lib/models/comic_data\.dart")

if [ -n "$QUEST_CHANGES" ] || [ -n "$ENGINE_CHANGES" ]; then
  echo ""
  echo "🔍  Eseguo narrative-flow-checker..."
  CHECKER="$ROOT/.github/skills/narrative-flow-checker/scripts/check-narrative-flow.cjs"
  if [ -f "$CHECKER" ]; then
    node "$CHECKER" "$ROOT"
    if [ $? -ne 0 ]; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  ❌  NARRATIVE FLOW CHECK FALLITO — commit bloccato         ║"
      echo "╠══════════════════════════════════════════════════════════════╣"
      echo "║  Ci sono inconsistenze narrative nei percorsi simulati.     ║"
      echo "║  Correggi i problemi segnalati sopra prima di committare.   ║"
      echo "║                                                              ║"
      echo "║  Override: git commit --no-verify                          ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
  else
    echo "⚠️   check-narrative-flow.cjs non trovato, skip."
  fi
fi

# ─── Doc freshness check ─────────────────────────────────────────────────────
# Prende il mtime più recente tra tutti i doc Obsidian (stat -L segue i symlink).
NOW=$(date +%s)
last_update=0
for doc in "${DOC_FILES[@]}"; do
  mtime=$(stat -L -f %m "$doc" 2>/dev/null || echo 0)
  [ "$mtime" -gt "$last_update" ] && last_update=$mtime
done
elapsed=$(( NOW - last_update ))

if [ "$elapsed" -gt "$GRACE" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  📚  DOCUMENTAZIONE NON AGGIORNATA — commit bloccato        ║"
  echo "╠══════════════════════════════════════════════════════════════╣"
  echo "║  File narrativi nel commit:                                  ║"
  while IFS= read -r f; do
    [ -n "$f" ] && printf "║    • %-56s║\n" "$f"
  done <<< "$NARRATIVE"
  echo "╠══════════════════════════════════════════════════════════════╣"
  printf "║  Docs Obsidian non aggiornate (ultima modifica: %3dm fa)  ║\n" "$(( elapsed / 60 ))"
  echo "║                                                              ║"
  echo "║  Aggiorna almeno uno di:                                     ║"
  echo "║    • docs/NARRATIVE_BIBLE.md  (minigame table, authoring)   ║"
  echo "║    • docs/MAPPA_NARRATIVA.md  (branch diagram mermaid)      ║"
  echo "║    • docs/LIBRO_DEI_MONDI.md  (narrativa discorsiva)        ║"
  echo "║    • docs/IDEE_FUTURE.md      (episodi e idee future)       ║"
  echo "║                                                              ║"
  echo "║  Poi riprova. Override: git commit --no-verify              ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

min_ago=$(( elapsed / 60 ))
echo "📚  Docs aggiornate ${min_ago}m fa — ok."
exit 0
